---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  unit: string;
  unitSlug: string;
  lessonNumber: number;
  objectives: string[];
  duration?: string;
  phase?: string;
  prevLesson?: { slug: string; title: string } | null;
  nextLesson?: { slug: string; title: string } | null;
  teacherMode?: boolean;
}

const {
  title, unit, unitSlug, lessonNumber, objectives,
  duration = '60 min', phase = 'explain',
  prevLesson, nextLesson, teacherMode = false
} = Astro.props;

const phaseLabels: Record<string, string> = {
  engage: 'Engage', explain: 'Explain', elaborate: 'Elaborate', evaluate: 'Evaluate'
};
const phaseBadge: Record<string, string> = {
  engage:    'bg-amber-100 text-amber-800',
  explain:   'bg-blue-100 text-blue-800',
  elaborate: 'bg-violet-100 text-violet-800',
  evaluate:  'bg-emerald-100 text-emerald-800',
};
---

<BaseLayout title={`Lesson ${lessonNumber}: ${title}`} teacherMode={teacherMode}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6">
    <a href="/" class="hover:text-slate-600">Home</a>
    <span>/</span>
    <a href={`/units/${unitSlug}`} class="hover:text-slate-600">{unit}</a>
    <span>/</span>
    <span class="text-slate-700 font-medium">Lesson {lessonNumber}</span>
  </nav>

  <!-- Lesson header -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-2">
      <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${phaseBadge[phase]}`}>
        {phaseLabels[phase]}
      </span>
      <span class="text-xs text-slate-400">{duration}</span>
      {teacherMode && (
        <a href={`/teacher/${unitSlug}/lesson-${String(lessonNumber).padStart(2,'0')}`}
           class="ml-auto text-xs text-teacher-600 hover:text-teacher-800 font-medium border border-teacher-300 px-2 py-0.5 rounded-full">
          Teacher notes →
        </a>
      )}
    </div>
    <h1 class="text-3xl font-bold text-slate-900">
      <span class="text-slate-400 font-normal text-xl mr-2">Lesson {lessonNumber}</span>
      {title}
    </h1>
  </div>

  <!-- Objectives -->
  <div class="bg-white rounded-xl border border-slate-200 p-4 mb-8">
    <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">By the end of this lesson</p>
    <ul class="space-y-1">
      {objectives.map(obj => (
        <li class="flex items-start gap-2 text-sm text-slate-700">
          <svg class="w-4 h-4 text-science-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
          {obj}
        </li>
      ))}
    </ul>
  </div>

  <!-- Main content -->
  <div class="prose max-w-none">
    <slot />
  </div>

  <!-- Prev / Next navigation -->
  <div class="flex justify-between items-center mt-12 pt-6 border-t border-slate-200">
    {prevLesson ? (
      <a href={`/units/${unitSlug}/${prevLesson.slug}`}
         class="flex items-center gap-2 text-sm text-slate-500 hover:text-science-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span><span class="text-slate-400">Prev: </span>{prevLesson.title}</span>
      </a>
    ) : <div />}
    {nextLesson ? (
      <a href={`/units/${unitSlug}/${nextLesson.slug}`}
         class="flex items-center gap-2 text-sm text-slate-500 hover:text-science-700 transition-colors">
        <span><span class="text-slate-400">Next: </span>{nextLesson.title}</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ) : <div />}
  </div>
</BaseLayout>
