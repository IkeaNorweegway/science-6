---
import Nav from '../components/Nav.astro';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Alberta curriculum classroom materials — Grade 6 Science, Grade 7 Science, and Math 9" />
    <title>Classroom Tools | Alberta Curriculum</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="flex items-center h-14">
          <span class="font-bold text-base tracking-tight text-slate-700">Classroom Tools</span>
        </div>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 py-16 sm:px-6">
      <div class="mb-12">
        <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">Alberta Curriculum</p>
        <h1 class="text-4xl font-bold text-slate-900 mb-3">Classroom Tools</h1>
        <p class="text-slate-500 text-lg max-w-xl">
          Evidence-based materials for Alberta classrooms. Choose a course.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Grade 6 Science -->
        <a
          href={`${base}materials`}
          class="group block bg-white rounded-2xl border border-slate-200 border-l-4 border-l-science-500 p-7 hover:bg-science-50 transition-colors"
        >
          <p class="text-xs font-bold uppercase tracking-widest text-science-600 mb-2">Grade 6</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-3">Science</h2>
          <p class="text-sm text-slate-500 leading-relaxed mb-6">
            Six units. Guided notes, workbooks, easy-read and French versions. Alberta curriculum 2023.
          </p>
          <div class="flex gap-3 mb-6 flex-wrap">
            <span class="text-xs bg-cyan-100 text-cyan-800 font-semibold px-2.5 py-1 rounded-full">6 units</span>
            <span class="text-xs bg-cyan-100 text-cyan-800 font-semibold px-2.5 py-1 rounded-full">~28 weeks</span>
            <span class="text-xs bg-cyan-100 text-cyan-800 font-semibold px-2.5 py-1 rounded-full">EN · EF · FR</span>
          </div>
          <span class="text-sm font-semibold text-science-700 group-hover:underline">View materials →</span>
        </a>

        <!-- Math 9 -->
        <a
          href={`${base}math9`}
          class="group block bg-white rounded-2xl border border-slate-200 border-l-4 border-l-math9-500 p-7 hover:bg-math9-50 transition-colors"
        >
          <p class="text-xs font-bold uppercase tracking-widest text-math9-600 mb-2">Grade 9</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-3">Mathematics</h2>
          <p class="text-sm text-slate-500 leading-relaxed mb-6">
            Four strands, eleven topics. Guided notes, concept pages, worksheets, exit tickets. Alberta curriculum.
          </p>
          <div class="flex gap-3 mb-6 flex-wrap">
            <span class="text-xs bg-math9-100 text-math9-800 font-semibold px-2.5 py-1 rounded-full">4 strands</span>
            <span class="text-xs bg-math9-100 text-math9-800 font-semibold px-2.5 py-1 rounded-full">11 topics</span>
            <span class="text-xs bg-math9-100 text-math9-800 font-semibold px-2.5 py-1 rounded-full">98 materials</span>
          </div>
          <span class="text-sm font-semibold text-math9-700 group-hover:underline">View materials →</span>
        </a>

        <!-- Grade 7 Science -->
        <a
          href={`${base}science7`}
          class="group block bg-white rounded-2xl border border-slate-200 border-l-4 p-7 transition-colors hover:opacity-90"
          style="border-left-color: #059669;"
        >
          <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #059669;">Grade 7</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-3">Science</h2>
          <p class="text-sm text-slate-500 leading-relaxed mb-6">
            Five units. Notes, workbooks, quizzes, tests, and answer keys. Alberta 2007 curriculum.
          </p>
          <div class="flex gap-3 mb-6 flex-wrap">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color: #d1fae5; color: #047857;">5 units</span>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color: #d1fae5; color: #047857;">~26 weeks</span>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color: #d1fae5; color: #047857;">40 materials</span>
          </div>
          <span class="text-sm font-semibold group-hover:underline" style="color: #047857;">View materials →</span>
        </a>

      </div>
    </main>

    <footer class="border-t border-slate-200 mt-20 py-8 text-center text-sm text-slate-400">
      Alberta Curriculum · Built for learning
    </footer>
  </body>
</html>
