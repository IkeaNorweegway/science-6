---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return [
    { params: { unit: 'interactions-ecosystems' } },
    { params: { unit: 'plants-food-fibre' } },
    { params: { unit: 'heat-temperature' } },
    { params: { unit: 'structures-forces' } },
    { params: { unit: 'planet-earth' } },
  ];
}

const { unit } = Astro.params;

type MaterialFile = { label: string; badge?: string; badgeStyle?: string; doc: string };
type Section = { heading: string; items: MaterialFile[] };

interface UnitData {
  label: string;
  tagline: string;
  color: string;
  colorDark: string;
  colorLight: string;
  colorBorder: string;
  sections: Section[];
  assessments: MaterialFile[];
  answerKeys: MaterialFile[];
}

const b = base;

