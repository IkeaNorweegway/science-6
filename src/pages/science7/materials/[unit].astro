const data = units[unit];
const borderStyle = `border-left-color: ${data.color};`;
---

<BaseLayout title={`${data.label} — Materials`} course="science7">

  <!-- Back link -->
  <a href={`${base}science7`} class="inline-flex items-center gap-1 text-sm text-slate-400 hover:text-slate-600 mb-8 transition-colors">
    ← Grade 7 Science
  </a>

  <!-- Header -->
  <div class="mb-10">
    <p class="text-xs font-bold uppercase tracking-widest mb-2" style={`color: ${data.colorDark};`}>Grade 7 Science</p>
    <h1 class="text-4xl font-bold text-slate-900 mb-3">{data.label}</h1>
    <p class="text-slate-500 text-lg max-w-xl">{data.tagline}</p>
  </div>

  <!-- Material sections -->
  {data.sections.map(section => (
    <section class="mb-10">
      <h2 class="text-xs font-bold uppercase tracking-widest mb-3" style={`color: ${data.colorDark};`}>{section.heading}</h2>
      <div class="space-y-2">
        {section.items.map(item => (
          <div class="bg-white rounded-xl border border-slate-200 border-l-4 px-5 py-4 flex items-center justify-between gap-4" style={borderStyle}>
            <div class="flex items-center gap-2 min-w-0">
              <span class="text-sm font-medium text-slate-800">{item.label}</span>
              {item.badge && (
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${item.badgeStyle}`}>{item.badge}</span>
              )}
            </div>
            <a
              href={`${base}science7/view/${unit}/${item.doc}`}
              class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors whitespace-nowrap"
            >
              Open
            </a>
          </div>
        ))}
      </div>
    </section>
  ))}

  <!-- Assessments section -->
  <section class="mb-10">
    <h2 class="text-xs font-bold uppercase tracking-widest mb-3" style={`color: ${data.colorDark};`}>Assessments</h2>
    <div class="space-y-2">
      {data.assessments.map(item => (
        <div class="bg-white rounded-xl border border-slate-200 border-l-4 px-5 py-4 flex items-center justify-between gap-4" style={borderStyle}>
          <div class="flex items-center gap-2 min-w-0">
            <span class="text-sm font-medium text-slate-800">{item.label}</span>
          </div>
          <a
            href={`${base}science7/view/${unit}/${item.doc}`}
            class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors whitespace-nowrap"
          >
            Open
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Answer keys — hidden by default -->
  <details class="group mt-2">
    <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none mb-3">
      <span class="inline-block transition-transform group-open:rotate-90">▶</span>
      Show answer keys
    </summary>
    <div class="space-y-2 mt-1">
      {data.answerKeys.map(item => (
        <div class="bg-slate-50 rounded-xl border border-slate-200 px-5 py-4 flex items-center justify-between gap-4">
          <div class="flex items-center gap-2 min-w-0">
            <span class="text-sm font-medium text-slate-600">{item.label}</span>
            <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600 tracking-wide">Answer Key</span>
          </div>
          <a
            href={`${base}science7/view/${unit}/${item.doc}`}
            class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors whitespace-nowrap"
          >
            Open
          </a>
        </div>
      ))}
    </div>
  </details>

</BaseLayout>
