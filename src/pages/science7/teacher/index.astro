---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const units = [
  {
    slug: 'interactions-ecosystems',
    label: 'Interactions and Ecosystems',
    tier: 1,
    weeks: '6–7',
    color: '#059669',
    colorDark: '#047857',
    colorLight: '#d1fae5',
    colorBorder: '#6ee7b7',
    tagStyle: 'bg-emerald-100 text-emerald-800',
    teacherGuideVersion: 2,
    misconceptions: ['Ecosystems can recover from any disturbance', 'Decomposers are not important', 'Food chains are linear in nature'],
  },
  {
    slug: 'plants-food-fibre',
    label: 'Plants for Food and Fibre',
    tier: 1,
    weeks: '5–6',
    color: '#16a34a',
    colorDark: '#15803d',
    colorLight: '#dcfce7',
    colorBorder: '#86efac',
    tagStyle: 'bg-green-100 text-green-800',
    teacherGuideVersion: 2,
    misconceptions: ['Plants get food from soil', 'Photosynthesis and respiration are opposites', 'GMO and selective breeding are the same'],
  },
  {
    slug: 'heat-temperature',
    label: 'Heat and Temperature',
    tier: 1,
    weeks: '5–6',
    color: '#ea580c',
    colorDark: '#c2410c',
    colorLight: '#ffedd5',
    colorBorder: '#fdba74',
    tagStyle: 'bg-orange-100 text-orange-800',
    teacherGuideVersion: 3,
    misconceptions: ['Cold travels into warm spaces', 'Metal is colder than wood', 'Heat and temperature are the same'],
  },
  {
    slug: 'structures-forces',
    label: 'Structures and Forces',
    tier: 2,
    weeks: '5–6',
    color: '#7c3aed',
    colorDark: '#6d28d9',
    colorLight: '#ede9fe',
    colorBorder: '#c4b5fd',
    tagStyle: 'bg-violet-100 text-violet-800',
    teacherGuideVersion: 2,
    misconceptions: ['Simple machines reduce the work done', 'Heavier = more stable', 'Compression and tension are the same'],
  },
  {
    slug: 'planet-earth',
    label: 'Planet Earth',
    tier: 2,
    weeks: '4–5',
    color: '#d97706',
    colorDark: '#b45309',
    colorLight: '#fef3c7',
    colorBorder: '#fcd34d',
    tagStyle: 'bg-amber-100 text-amber-800',
    teacherGuideVersion: 2,
    misconceptions: ['Continents are fixed', 'Volcanoes and earthquakes happen everywhere', 'Sedimentary rocks form quickly'],
  },
];
---

<BaseLayout title="Science 7 — Teacher Hub" course="science7" teacherMode={true}>

  <div class="mb-8">
    <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #b45309;">Teacher Hub · Grade 7 Science</p>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Grade 7 Science — Teacher View</h1>
    <p class="text-slate-500">Teaching guides with SHOW / SAY / CUE delivery notes, misconception flags, and lab setup for all 5 units.</p>
  </div>

  <div class="space-y-4">
    {units.map(u => (
      <div
        class="bg-white rounded-xl border border-slate-200 border-l-4 overflow-hidden"
        style={`border-left-color: ${u.color};`}
      >
        <!-- Unit header -->
        <div class="px-5 py-4 flex items-start justify-between gap-4">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${u.tagStyle}`}>Tier {u.tier}</span>
              <span class="text-xs text-slate-400">{u.weeks} weeks</span>
            </div>
            <p class="font-bold text-slate-900">{u.label}</p>
            <p class="text-xs text-slate-400 mt-1">
              Key misconceptions: {u.misconceptions.join(' · ')}
            </p>
          </div>
        </div>

        <!-- Teaching guide link -->
        <div class="border-t border-slate-100 px-5 py-3 flex items-center justify-between gap-4 bg-amber-50">
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-amber-600 text-white">Teaching Guide</span>
            <span class="text-sm font-medium text-slate-700">SHOW / SAY / CUE · Lesson Sequence · Lab Notes</span>
          </div>
          <a
            href={`${base}science7/view/${u.slug}/sci7-${u.slug}-teacherguide-v${u.teacherGuideVersion}`}
            target="_blank"
            rel="noopener"
            class="flex-shrink-0 text-sm font-semibold text-amber-700 hover:text-amber-900 border border-amber-300 hover:border-amber-500 px-4 py-1.5 rounded-lg transition-colors whitespace-nowrap"
          >
            Open ↗
          </a>
        </div>

        <!-- Answer keys (collapsed) -->
        <div class="border-t border-slate-100 px-5 py-3">
          <details class="group">
            <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none">
              <span class="inline-block transition-transform group-open:rotate-90">▶</span>
              Answer keys
            </summary>
            <div class="mt-3 space-y-2">
              {[
                { label: 'Notes Answer Key',       doc: `sci7-${u.slug}-notes-answers-v1` },
                { label: 'Workbook Answer Key',    doc: `sci7-${u.slug}-workbook-answers-v1` },
                { label: 'Assessment Answer Key',  doc: `sci7-${u.slug}-assessment-answers-v1` },
              ].map(ak => (
                <div class="bg-slate-50 rounded-lg border border-slate-200 px-4 py-2.5 flex items-center justify-between gap-4">
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Answer Key</span>
                    <span class="text-sm font-medium text-slate-600">{ak.label}</span>
                  </div>
                  <a
                    href={`${base}science7/view/${u.slug}/${ak.doc}`}
                    target="_blank"
                    rel="noopener"
                    class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors"
                  >
                    Open ↗
                  </a>
                </div>
              ))}
            </div>
          </details>
        </div>

      </div>
    ))}
  </div>

  <div class="mt-10 pt-6 border-t border-slate-100">
    <a href={`${base}science7`} class="text-sm text-slate-400 hover:text-slate-600 transition-colors">
      ← Back to Grade 7 Science
    </a>
  </div>

</BaseLayout>
