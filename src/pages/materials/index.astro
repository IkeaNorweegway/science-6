---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const unitCards = [
  {
    slug: 'matter',
    label: 'Matter',
    description: 'Particle model, states of matter, phase changes, thermometers, expansion, and the water anomaly.',
    bg: 'bg-cyan-50', text: 'text-cyan-800', border: 'border-cyan-400', link: 'text-cyan-700', hover: 'hover:bg-cyan-100',
  },
  {
    slug: 'forces',
    label: 'Forces',
    description: 'Pushes and pulls, external and internal forces, elasticity, plasticity, and Newton\'s Third Law.',
    bg: 'bg-violet-50', text: 'text-violet-800', border: 'border-violet-400', link: 'text-violet-700', hover: 'hover:bg-violet-100',
  },
  {
    slug: 'living-systems',
    label: 'Living Systems',
    description: 'Biotic and abiotic factors, photosynthesis, food webs, trophic cascades, and Indigenous ecological knowledge.',
    bg: 'bg-emerald-50', text: 'text-emerald-800', border: 'border-emerald-400', link: 'text-emerald-700', hover: 'hover:bg-emerald-100',
  },
  {
    slug: 'climate',
    label: 'Climate',
    description: 'Weather vs. climate, greenhouse effect, causes of climate change, and Alberta-specific impacts.',
    bg: 'bg-amber-50', text: 'text-amber-800', border: 'border-amber-400', link: 'text-amber-700', hover: 'hover:bg-amber-100',
  },
  {
    slug: 'energy-resources',
    label: 'Energy Resources',
    description: 'Renewable vs. non-renewable energy, before and after processing, and the five selection factors.',
    bg: 'bg-orange-50', text: 'text-orange-800', border: 'border-orange-400', link: 'text-orange-700', hover: 'hover:bg-orange-100',
  },
  {
    slug: 'space',
    label: 'Space',
    description: 'Solar system objects, exploration technologies, satellites, orbital mechanics, and the ISS.',
    bg: 'bg-indigo-50', text: 'text-indigo-800', border: 'border-indigo-400', link: 'text-indigo-700', hover: 'hover:bg-indigo-100',
  },
];
---

<BaseLayout title="Materials">
  <div class="mb-10">
    <p class="text-xs font-bold uppercase tracking-widest text-science-600 mb-2">Grade 6 Science</p>
    <h1 class="text-4xl font-bold text-slate-900 mb-3">Materials</h1>
    <p class="text-slate-500 text-lg max-w-xl">
      Pick the unit your child is studying. You'll find notes, a practice workbook, and answer keys — all in one place.
    </p>
  </div>

  <!-- Unit cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    {unitCards.map(u => (
      <a
        href={`${base}materials/${u.slug}`}
        class={`group block bg-white rounded-xl border border-slate-200 border-l-4 ${u.border} p-5 transition-colors ${u.hover}`}
      >
        <p class={`text-xs font-bold uppercase tracking-widest ${u.text} mb-2`}>{u.label}</p>
        <p class="text-sm text-slate-500 mb-4 leading-relaxed">{u.description}</p>
        <span class={`text-sm font-semibold ${u.link} group-hover:underline`}>View materials →</span>
      </a>
    ))}
  </div>

  <!-- Year Review + Français -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <a
      href={`${base}materials/year-review`}
      class="group block bg-white rounded-xl border border-slate-200 border-l-4 border-science-400 p-5 transition-colors hover:bg-science-50"
    >
      <p class="text-xs font-bold uppercase tracking-widest text-science-700 mb-2">Year Review</p>
      <p class="text-sm text-slate-500 mb-4 leading-relaxed">End-of-year review covering all six units. Notes and a mixed-topic practice workbook.</p>
      <span class="text-sm font-semibold text-science-700 group-hover:underline">View materials →</span>
    </a>

    <a
      href={`${base}materials/fr`}
      class="group block bg-white rounded-xl border border-slate-200 border-l-4 border-blue-400 p-5 transition-colors hover:bg-blue-50"
    >
      <p class="text-xs font-bold uppercase tracking-widest text-blue-700 mb-2">Français — Immersion</p>
      <p class="text-sm text-slate-500 mb-4 leading-relaxed">Notes guidées et cahiers d'exercices en français pour toutes les unités. Niveau H–I.</p>
      <span class="text-sm font-semibold text-blue-700 group-hover:underline">Voir les matériaux →</span>
    </a>
  </div>
</BaseLayout>
