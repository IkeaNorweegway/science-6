  const exits = [
    'exits/rational-numbers/math9-rational-numbers-exits-v1',
    'exits/square-roots/math9-square-roots-exits-v1',
    'exits/powers-exponents/math9-powers-exits-v1',
    'exits/linear-relations/math9-linear-relations-exits-v1',
    'exits/linear-equations/math9-linear-equations-exits-v1',
    'exits/polynomials/math9-polynomials-exits-v1',
    'exits/circle-geometry/math9-circle-geometry-exits-v1',
    'exits/measurement/math9-measurement-exits-v1',
    'exits/similarity/math9-similarity-exits-v1',
    'exits/statistics/math9-statistics-exits-v1',
    'exits/probability/math9-probability-exits-v1',
  ];

  return [...notes, ...worksheets, ...exits].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const fileUrl = `${base}materials/math-9/${slug}.html`;

// Derive a back link from the slug
function backHref(slug: string): string {
  if (slug.startsWith('notes/')) {
    const topic = slug.split('/')[1];
    const strandMap: Record<string, string> = {
      'rational-numbers': 'number', 'square-roots': 'number', 'powers-exponents': 'number',
      'linear-relations': 'algebra', 'linear-equations': 'algebra', 'polynomials': 'algebra',
      'circle-geometry': 'measurement-geometry', 'measurement': 'measurement-geometry', 'similarity': 'measurement-geometry',
      'statistics': 'statistics-probability', 'probability': 'statistics-probability',
    };
    const strand = strandMap[topic] ?? 'number';
    return `${base}math9/materials/${strand}`;
  }
  if (slug.startsWith('worksheets/')) {
    const strand = slug.split('/')[1];
    return `${base}math9/materials/${strand}`;
  }
  if (slug.startsWith('exits/')) {
    const topic = slug.split('/')[1];
    const strandMap: Record<string, string> = {
      'rational-numbers': 'number', 'square-roots': 'number', 'powers-exponents': 'number',
      'linear-relations': 'algebra', 'linear-equations': 'algebra', 'polynomials': 'algebra',
      'circle-geometry': 'measurement-geometry', 'measurement': 'measurement-geometry', 'similarity': 'measurement-geometry',
      'statistics': 'statistics-probability', 'probability': 'statistics-probability',
    };
    const strand = strandMap[topic] ?? 'number';
    return `${base}math9/materials/${strand}`;
  }
  return `${base}math9/materials`;
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Math 9 — {slug}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <style>
    html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
    .viewer-shell { display: flex; flex-direction: column; height: 100vh; }
    .back-bar { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 0.4rem 1.25rem; flex-shrink: 0; }
    .back-bar a { font-family: system-ui, -apple-system, sans-serif; font-size: 0.8rem; color: #64748b; text-decoration: none; }
    .back-bar a:hover { color: #0f172a; }
    .doc-frame { flex: 1; border: none; width: 100%; display: block; }
    @media print {
      .viewer-nav, .back-bar { display: none !important; }
      .doc-frame { height: 100vh; }
    }
  </style>
</head>
<body>
  <div class="viewer-shell">
    <div class="viewer-nav">
      <Nav course="math9" />
    </div>
    <div class="back-bar">
      <a href={backHref(slug)}>← Back</a>
    </div>
    <iframe src={fileUrl} class="doc-frame" title={slug} />
  </div>
</body>
</html>
