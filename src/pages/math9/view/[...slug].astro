    'notes/powers-exponents/math9-powers-teachernotes-v1',
    'notes/linear-relations/math9-linear-relations-notes-v1',
    'notes/linear-relations/math9-linear-relations-notes-answers-v1',
    'notes/linear-relations/math9-linear-relations-teachernotes-v1',
    'notes/linear-equations/math9-linear-equations-notes-v1',
    'notes/linear-equations/math9-linear-equations-notes-answers-v1',
    'notes/linear-equations/math9-linear-equations-teachernotes-v1',
    'notes/polynomials/math9-polynomials-notes-v1',
    'notes/polynomials/math9-polynomials-notes-answers-v1',
    'notes/polynomials/math9-polynomials-teachernotes-v1',
    'notes/circle-geometry/math9-circle-geometry-notes-v1',
