    'notes/circle-geometry/math9-circle-geometry-teachernotes-v1',
    'notes/measurement/math9-measurement-notes-v1',
    'notes/measurement/math9-measurement-notes-answers-v1',
    'notes/measurement/math9-measurement-teachernotes-v1',
    'notes/similarity/math9-similarity-notes-v1',
    'notes/similarity/math9-similarity-notes-answers-v1',
    'notes/similarity/math9-similarity-teachernotes-v1',
    'notes/statistics/math9-statistics-notes-v1',
    'notes/statistics/math9-statistics-notes-answers-v1',
    'notes/statistics/math9-statistics-teachernotes-v1',
    'notes/probability/math9-probability-notes-v1',
    'notes/probability/math9-probability-notes-answers-v1',
    'notes/probability/math9-probability-teachernotes-v1',
  ];

  const worksheets = [
    // Number
    'worksheets/number/math9-number-workbook-v1',
    'worksheets/number/math9-number-workbook-answers-v1',
    'worksheets/number/rational-numbers/math9-rational-numbers-concepts-v1',
    'worksheets/number/rational-numbers/math9-rational-numbers-worksheet-core-v1',
    'worksheets/number/rational-numbers/math9-rational-numbers-worksheet-core-answers-v1',
    'worksheets/number/rational-numbers/math9-rational-numbers-worksheet-challenge-v1',
    'worksheets/number/rational-numbers/math9-rational-numbers-worksheet-challenge-answers-v1',
    'worksheets/number/square-roots/math9-square-roots-concepts-v1',
    'worksheets/number/square-roots/math9-square-roots-worksheet-core-v1',
    'worksheets/number/square-roots/math9-square-roots-worksheet-core-answers-v1',
    'worksheets/number/square-roots/math9-square-roots-worksheet-challenge-v1',
    'worksheets/number/square-roots/math9-square-roots-worksheet-challenge-answers-v1',
    'worksheets/number/powers-exponents/math9-powers-concepts-v1',
    'worksheets/number/powers-exponents/math9-powers-worksheet-core-v1',
    'worksheets/number/powers-exponents/math9-powers-worksheet-core-answers-v1',
    'worksheets/number/powers-exponents/math9-powers-worksheet-challenge-v1',
    'worksheets/number/powers-exponents/math9-powers-worksheet-challenge-answers-v1',
    'worksheets/number/powers-exponents/math9-powers-repeated-mult-lesson-v1',
    // Algebra
    'worksheets/algebra/math9-algebra-workbook-v1',
    'worksheets/algebra/math9-algebra-workbook-answers-v1',
    'worksheets/algebra/linear-relations/math9-linear-relations-concepts-v1',
    'worksheets/algebra/linear-relations/math9-linear-relations-worksheet-core-v1',
    'worksheets/algebra/linear-relations/math9-linear-relations-worksheet-core-answers-v1',
    'worksheets/algebra/linear-relations/math9-linear-relations-worksheet-challenge-v1',
    'worksheets/algebra/linear-relations/math9-linear-relations-worksheet-challenge-answers-v1',
    'worksheets/algebra/linear-equations/math9-linear-equations-concepts-v1',
    'worksheets/algebra/linear-equations/math9-linear-equations-worksheet-core-v1',
