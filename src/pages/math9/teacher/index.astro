---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

function viewHref(path: string) { return `${base}math9/view/${path}`; }

const strands = [
  {
    label: 'Number',
    color: 'border-l-blue-400',
    tagStyle: 'bg-blue-100 text-blue-800',
    topics: [
      { label: 'Rational Numbers',   slug: 'rational-numbers', wsSlug: 'math9-rational-numbers' },
      { label: 'Square Roots',       slug: 'square-roots',     wsSlug: 'math9-square-roots' },
      { label: 'Powers & Exponents', slug: 'powers-exponents', wsSlug: 'math9-powers' },
    ],
    wsBase: 'number',
  },
  {
    label: 'Algebra',
    color: 'border-l-violet-400',
    tagStyle: 'bg-violet-100 text-violet-800',
    topics: [
      { label: 'Linear Relations',                slug: 'linear-relations', wsSlug: 'math9-linear-relations' },
      { label: 'Linear Equations & Inequalities', slug: 'linear-equations', wsSlug: 'math9-linear-equations' },
      { label: 'Polynomials',                     slug: 'polynomials',      wsSlug: 'math9-polynomials' },
    ],
    wsBase: 'algebra',
  },
  {
    label: 'Measurement & Geometry',
    color: 'border-l-green-400',
    tagStyle: 'bg-green-100 text-green-800',
    topics: [
      { label: 'Circle Geometry',       slug: 'circle-geometry', wsSlug: 'math9-circle-geometry' },
      { label: 'Surface Area & Volume', slug: 'measurement',     wsSlug: 'math9-measurement' },
      { label: 'Similarity & Scale',    slug: 'similarity',      wsSlug: 'math9-similarity' },
    ],
    wsBase: 'measurement-geometry',
  },
  {
    label: 'Statistics & Probability',
    color: 'border-l-teal-400',
    tagStyle: 'bg-teal-100 text-teal-800',
    topics: [
      { label: 'Statistics & Scatter Plots', slug: 'statistics', wsSlug: 'math9-statistics' },
      { label: 'Probability',                slug: 'probability', wsSlug: 'math9-probability' },
    ],
    wsBase: 'statistics-probability',
  },
];
---

<BaseLayout title="Math 9 — Teacher Hub" course="math9" teacherMode={true}>

  <div class="mb-8">
    <p class="text-xs font-bold uppercase tracking-widest text-teacher-600 mb-2">Teacher Hub · Math 9</p>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Grade 9 Mathematics — Teacher View</h1>
    <p class="text-slate-500">Teaching guides, answer keys, and delivery notes for all 11 topics.</p>
  </div>

  {strands.map(strand => (
    <section class="mb-12">
      <h2 class={`text-xs font-bold uppercase tracking-widest mb-4 pb-2 border-b border-slate-100 text-slate-500`}>
        {strand.label}
      </h2>

      <div class="space-y-3">
        {strand.topics.map(t => (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${strand.color} px-5 py-4`}>
            <div class="flex items-center justify-between gap-4 mb-3">
              <div class="flex items-center gap-2">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${strand.tagStyle}`}>{strand.label}</span>
                <span class="text-sm font-bold text-slate-800">{t.label}</span>
              </div>
            </div>
            <div class="space-y-2">
              <!-- Teaching guide -->
              <div class="flex items-center justify-between gap-4 bg-amber-50 rounded-lg border border-amber-200 px-4 py-2.5">
                <div class="flex items-center gap-2">
                  <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-teacher-600 text-white">Teaching Guide</span>
                  <span class="text-sm font-medium text-slate-700">SHOW / SAY / CUE Delivery Notes</span>
                </div>
                <a
                  href={viewHref(`notes/${t.slug}/${t.wsSlug}-teachernotes-v1`)}
                  target="_blank"
                  rel="noopener"
                  class="flex-shrink-0 text-sm font-semibold text-teacher-700 hover:text-teacher-900 border border-teacher-300 hover:border-teacher-500 px-4 py-1.5 rounded-lg transition-colors whitespace-nowrap"
                >
                  Open ↗
                </a>
              </div>
              <!-- Answer keys -->
              <details class="group">
                <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none px-1 py-1">
                  <span class="inline-block transition-transform group-open:rotate-90">▶</span> Answer keys
                </summary>
                <div class="mt-2 space-y-1.5">
                  {[
                    { label: 'Notes Answer Key',             path: `notes/${t.slug}/${t.wsSlug}-notes-answers-v1` },
                    { label: 'Core Worksheet Answer Key',    path: `worksheets/${strand.wsBase}/${t.slug}/${t.wsSlug}-worksheet-core-answers-v1` },
                    { label: 'Challenge Answer Key',         path: `worksheets/${strand.wsBase}/${t.slug}/${t.wsSlug}-worksheet-challenge-answers-v1` },
                  ].map(ak => (
                    <div class="bg-slate-50 rounded-lg border border-slate-200 px-4 py-2.5 flex items-center justify-between gap-4">
                      <div class="flex items-center gap-2">
                        <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Answer Key</span>
                        <span class="text-sm font-medium text-slate-600">{ak.label}</span>
                      </div>
                      <a
                        href={viewHref(ak.path)}
                        target="_blank"
                        rel="noopener"
                        class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors"
                      >
                        Open ↗
                      </a>
                    </div>
                  ))}
                </div>
              </details>
            </div>
          </div>
        ))}
      </div>
    </section>
  ))}

</BaseLayout>
