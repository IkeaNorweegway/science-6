---
import Math9Layout from '../../../layouts/Math9Layout.astro';
const base = import.meta.env.BASE_URL;
const b = base;

const border = 'border-blue-400';
const text   = 'text-blue-800';
const bg     = 'bg-blue-50';

type Item = { label: string; badge?: string; badgeStyle?: string; href: string };
type Section = { heading: string; items: Item[] };

function viewHref(path: string) {
  return `${b}math9/view/${path}`;
}

const topics: { label: string; slug: string; noteSlug: string; wsSlug: string; exitSlug: string }[] = [
  { label: 'Rational Numbers',    slug: 'rational-numbers',  noteSlug: 'math9-rational-numbers-notes-v1',    wsSlug: 'math9-rational-numbers', exitSlug: 'math9-rational-numbers-exits-v1' },
  { label: 'Square Roots',        slug: 'square-roots',      noteSlug: 'math9-square-roots-notes-v1',        wsSlug: 'math9-square-roots',     exitSlug: 'math9-square-roots-exits-v1' },
  { label: 'Powers & Exponents',  slug: 'powers-exponents',  noteSlug: 'math9-powers-notes-v1',              wsSlug: 'math9-powers',           exitSlug: 'math9-powers-exits-v1' },
];
---

<Math9Layout title="Number — Math 9 Materials">

  <a href={`${b}math9/materials`} class="inline-flex items-center gap-1 text-sm text-slate-400 hover:text-slate-600 mb-8 transition-colors">
    ← All strands
  </a>

  <div class="border-l-4 border-blue-400 pl-5 mb-6">
    <div class="flex items-center gap-2 mb-1 flex-wrap">
      <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Grade 9 Mathematics</span>
      <span class="text-xs font-semibold bg-blue-100 text-blue-800 px-2 py-0.5 rounded-full">3 topics</span>
      <span class="text-xs font-semibold bg-slate-100 text-slate-600 px-2 py-0.5 rounded-full">Number strand</span>
    </div>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Number</h1>
    <p class="text-slate-500 italic text-base">Rational Numbers · Square Roots · Powers &amp; Exponents</p>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4 mb-10">
    <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Strand Focus</p>
    <p class="text-slate-700">Operations with rational numbers, estimating and calculating square roots, the Pythagorean theorem, and the full set of exponent laws — including product, quotient, power, and zero exponents.</p>
  </div>

  <!-- Strand workbook -->
  <section class="mb-10">
    <h2 class="text-xs font-bold uppercase tracking-widest text-blue-700 mb-3">Strand Workbook</h2>
    <div class="space-y-2">
      <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
        <span class="text-sm font-medium text-slate-800">Number — Strand Workbook</span>
        <a href={viewHref(`worksheets/number/math9-number-workbook-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
      </div>
    </div>
    <details class="group mt-3">
      <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none">
        <span class="inline-block transition-transform group-open:rotate-90">▶</span> Workbook answer key
      </summary>
      <div class="mt-2 space-y-2">
        <div class="bg-slate-50 rounded-xl border border-slate-200 px-5 py-4 flex items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-600">Number Workbook Answer Key</span>
            <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Answer Key</span>
          </div>
          <a href={viewHref(`worksheets/number/math9-number-workbook-answers-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
        </div>
      </div>
    </details>
  </section>

  <!-- Per-topic sections -->
  {topics.map(t => (
    <section class="mb-12">
      <h2 class={`text-sm font-bold ${text} mb-4 pb-2 border-b border-slate-100`}>{t.label}</h2>

      <div class="space-y-2 mb-3">
        <!-- Notes -->
        <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-800">Guided Notes</span>
            <span class="text-xs bg-blue-100 text-blue-800 font-semibold px-2 py-0.5 rounded-full">Notes</span>
          </div>
          <a href={viewHref(`notes/${t.slug}/${t.noteSlug}`)} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
        </div>
        <!-- Concept page -->
        <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-800">Concept Reference</span>
            <span class="text-xs bg-slate-100 text-slate-700 font-semibold px-2 py-0.5 rounded-full">Reference</span>
          </div>
          <a href={viewHref(`worksheets/number/${t.slug}/${t.wsSlug}-concepts-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
        </div>
        <!-- Core worksheet -->
        <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-800">Core Practice</span>
            <span class="text-xs bg-blue-100 text-blue-800 font-semibold px-2 py-0.5 rounded-full">★</span>
          </div>
          <a href={viewHref(`worksheets/number/${t.slug}/${t.wsSlug}-worksheet-core-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
        </div>
        <!-- Challenge worksheet -->
        <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-800">Challenge</span>
            <span class="text-xs bg-blue-100 text-blue-800 font-semibold px-2 py-0.5 rounded-full">★★</span>
          </div>
          <a href={viewHref(`worksheets/number/${t.slug}/${t.wsSlug}-worksheet-challenge-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
        </div>
        <!-- Exit tickets -->
        <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-800">Exit Tickets</span>
            <span class="text-xs bg-slate-100 text-slate-700 font-semibold px-2 py-0.5 rounded-full">Formative</span>
          </div>
          <a href={viewHref(`exits/${t.slug}/${t.exitSlug}`)} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
        </div>
      </div>

      <!-- Answer keys collapsible -->
      <details class="group">
        <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none">
          <span class="inline-block transition-transform group-open:rotate-90">▶</span> Show answer keys
        </summary>
        <div class="mt-2 space-y-2">
          {[
            { label: 'Notes Answer Key', path: `notes/${t.slug}/${t.noteSlug.replace('-notes-v1', '-notes-answers-v1')}` },
            { label: 'Core Worksheet Answer Key', path: `worksheets/number/${t.slug}/${t.wsSlug}-worksheet-core-answers-v1` },
            { label: 'Challenge Answer Key', path: `worksheets/number/${t.slug}/${t.wsSlug}-worksheet-challenge-answers-v1` },
          ].map(ak => (
            <div class="bg-slate-50 rounded-xl border border-slate-200 px-5 py-4 flex items-center justify-between gap-4">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-slate-600">{ak.label}</span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Answer Key</span>
              </div>
              <a href={viewHref(ak.path)} class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
            </div>
          ))}
        </div>
      </details>
    </section>
  ))}

</Math9Layout>
