---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const b = base;
const border = 'border-violet-400';
const text   = 'text-violet-800';

function viewHref(path: string) { return `${b}math9/view/${path}`; }

const topics = [
  { label: 'Linear Relations',               slug: 'linear-relations',  noteSlug: 'math9-linear-relations-notes-v1',    wsSlug: 'math9-linear-relations',    exitSlug: 'math9-linear-relations-exits-v1' },
  { label: 'Linear Equations & Inequalities', slug: 'linear-equations',  noteSlug: 'math9-linear-equations-notes-v1',    wsSlug: 'math9-linear-equations',    exitSlug: 'math9-linear-equations-exits-v1' },
  { label: 'Polynomials',                     slug: 'polynomials',       noteSlug: 'math9-polynomials-notes-v1',          wsSlug: 'math9-polynomials',         exitSlug: 'math9-polynomials-exits-v1' },
];
---

<BaseLayout course="math9" title="Algebra — Math 9 Materials">
  <a href={`${b}math9/materials`} class="inline-flex items-center gap-1 text-sm text-slate-400 hover:text-slate-600 mb-8 transition-colors">← All strands</a>

  <div class="border-l-4 border-violet-400 pl-5 mb-6">
    <div class="flex items-center gap-2 mb-1 flex-wrap">
      <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Grade 9 Mathematics</span>
      <span class="text-xs font-semibold bg-violet-100 text-violet-800 px-2 py-0.5 rounded-full">3 topics</span>
      <span class="text-xs font-semibold bg-slate-100 text-slate-600 px-2 py-0.5 rounded-full">Algebra strand</span>
    </div>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Algebra</h1>
    <p class="text-slate-500 italic text-base">Linear Relations · Linear Equations &amp; Inequalities · Polynomials</p>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4 mb-10">
    <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Strand Focus</p>
    <p class="text-slate-700">Slope and y = mx + b, solving and graphing multi-step linear equations and inequalities, and polynomial operations including multiplying binomials.</p>
  </div>

  <section class="mb-10">
    <h2 class="text-xs font-bold uppercase tracking-widest text-violet-700 mb-3">Strand Workbook</h2>
    <div class="space-y-2">
      <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
        <span class="text-sm font-medium text-slate-800">Algebra — Strand Workbook</span>
        <a href={viewHref(`worksheets/algebra/math9-algebra-workbook-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
      </div>
    </div>
    <details class="group mt-3">
      <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none">
        <span class="inline-block transition-transform group-open:rotate-90">▶</span> Workbook answer key
      </summary>
      <div class="mt-2 space-y-2">
        <div class="bg-slate-50 rounded-xl border border-slate-200 px-5 py-4 flex items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-600">Algebra Workbook Answer Key</span>
            <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Answer Key</span>
          </div>
          <a href={viewHref(`worksheets/algebra/math9-algebra-workbook-answers-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
        </div>
      </div>
    </details>
  </section>

  {topics.map(t => (
    <section class="mb-12">
      <h2 class={`text-sm font-bold ${text} mb-4 pb-2 border-b border-slate-100`}>{t.label}</h2>
      <div class="space-y-2 mb-3">
        {[
          { label: 'Guided Notes',      badge: 'Notes',     badgeStyle: 'bg-violet-100 text-violet-800', href: viewHref(`notes/${t.slug}/${t.noteSlug}`) },
          { label: 'Concept Reference', badge: 'Reference', badgeStyle: 'bg-slate-100 text-slate-700',   href: viewHref(`worksheets/algebra/${t.slug}/${t.wsSlug}-concepts-v1`) },
          { label: 'Core Practice',     badge: '★',         badgeStyle: 'bg-violet-100 text-violet-800', href: viewHref(`worksheets/algebra/${t.slug}/${t.wsSlug}-worksheet-core-v1`) },
          { label: 'Challenge',         badge: '★★',        badgeStyle: 'bg-violet-100 text-violet-800', href: viewHref(`worksheets/algebra/${t.slug}/${t.wsSlug}-worksheet-challenge-v1`) },
          { label: 'Exit Tickets',      badge: 'Formative', badgeStyle: 'bg-slate-100 text-slate-700',   href: viewHref(`exits/${t.slug}/${t.exitSlug}`) },
          { label: 'Teaching Guide',    badge: 'Teacher',   badgeStyle: 'bg-slate-800 text-white',        href: viewHref(`notes/${t.slug}/${t.wsSlug}-teachernotes-v1`) },
        ].map(item => (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-slate-800">{item.label}</span>
              <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${item.badgeStyle}`}>{item.badge}</span>
            </div>
            <a href={item.href} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
          </div>
        ))}
      </div>
      <details class="group">
        <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none">
          <span class="inline-block transition-transform group-open:rotate-90">▶</span> Show answer keys
        </summary>
        <div class="mt-2 space-y-2">
          {[
            { label: 'Notes Answer Key',         path: `notes/${t.slug}/${t.noteSlug.replace('-notes-v1','-notes-answers-v1')}` },
            { label: 'Core Worksheet Answer Key', path: `worksheets/algebra/${t.slug}/${t.wsSlug}-worksheet-core-answers-v1` },
            { label: 'Challenge Answer Key',      path: `worksheets/algebra/${t.slug}/${t.wsSlug}-worksheet-challenge-answers-v1` },
          ].map(ak => (
            <div class="bg-slate-50 rounded-xl border border-slate-200 px-5 py-4 flex items-center justify-between gap-4">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-slate-600">{ak.label}</span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Answer Key</span>
              </div>
              <a href={viewHref(ak.path)} class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
            </div>
          ))}
        </div>
      </details>
    </section>
  ))}
</BaseLayout>
