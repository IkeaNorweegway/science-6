---
import Math9Layout from '../../../layouts/Math9Layout.astro';
const base = import.meta.env.BASE_URL;
const b = base;
const border = 'border-green-400';
const text   = 'text-green-800';

function viewHref(path: string) { return `${b}math9/view/${path}`; }

const topics = [
  { label: 'Circle Geometry',       slug: 'circle-geometry', noteSlug: 'math9-circle-geometry-notes-v1',    wsSlug: 'math9-circle-geometry',  exitSlug: 'math9-circle-geometry-exits-v1' },
  { label: 'Surface Area & Volume', slug: 'measurement',     noteSlug: 'math9-measurement-notes-v1',        wsSlug: 'math9-measurement',       exitSlug: 'math9-measurement-exits-v1' },
  { label: 'Similarity & Scale',    slug: 'similarity',      noteSlug: 'math9-similarity-notes-v1',         wsSlug: 'math9-similarity',        exitSlug: 'math9-similarity-exits-v1' },
];
---

<Math9Layout title="Measurement & Geometry — Math 9 Materials">
  <a href={`${b}math9/materials`} class="inline-flex items-center gap-1 text-sm text-slate-400 hover:text-slate-600 mb-8 transition-colors">← All strands</a>

  <div class="border-l-4 border-green-400 pl-5 mb-6">
    <div class="flex items-center gap-2 mb-1 flex-wrap">
      <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Grade 9 Mathematics</span>
      <span class="text-xs font-semibold bg-green-100 text-green-800 px-2 py-0.5 rounded-full">3 topics</span>
      <span class="text-xs font-semibold bg-slate-100 text-slate-600 px-2 py-0.5 rounded-full">Measurement &amp; Geometry strand</span>
    </div>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Measurement &amp; Geometry</h1>
    <p class="text-slate-500 italic text-base">Circle Geometry · Surface Area &amp; Volume · Similarity &amp; Scale</p>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4 mb-10">
    <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Strand Focus</p>
    <p class="text-slate-700">Chord and tangent properties of circles, surface area and volume of composite 3D objects, and similar triangles with scale diagrams and factors.</p>
  </div>

  <section class="mb-10">
    <h2 class="text-xs font-bold uppercase tracking-widest text-green-700 mb-3">Strand Workbook</h2>
    <div class="space-y-2">
      <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
        <span class="text-sm font-medium text-slate-800">Measurement &amp; Geometry — Strand Workbook</span>
        <a href={viewHref(`worksheets/measurement-geometry/math9-measurement-geometry-workbook-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
      </div>
    </div>
    <details class="group mt-3">
      <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none">
        <span class="inline-block transition-transform group-open:rotate-90">▶</span> Workbook answer key
      </summary>
      <div class="mt-2">
        <div class="bg-slate-50 rounded-xl border border-slate-200 px-5 py-4 flex items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-slate-600">M&amp;G Workbook Answer Key</span>
            <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Answer Key</span>
          </div>
          <a href={viewHref(`worksheets/measurement-geometry/math9-measurement-geometry-workbook-answers-v1`)} class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
        </div>
      </div>
    </details>
  </section>

  {topics.map(t => (
    <section class="mb-12">
      <h2 class={`text-sm font-bold ${text} mb-4 pb-2 border-b border-slate-100`}>{t.label}</h2>
      <div class="space-y-2 mb-3">
        {[
          { label: 'Guided Notes',      badge: 'Notes',     badgeStyle: 'bg-green-100 text-green-800', href: viewHref(`notes/${t.slug}/${t.noteSlug}`) },
          { label: 'Concept Reference', badge: 'Reference', badgeStyle: 'bg-slate-100 text-slate-700', href: viewHref(`worksheets/measurement-geometry/${t.slug}/${t.wsSlug}-concepts-v1`) },
          { label: 'Core Practice',     badge: '★',         badgeStyle: 'bg-green-100 text-green-800', href: viewHref(`worksheets/measurement-geometry/${t.slug}/${t.wsSlug}-worksheet-core-v1`) },
          { label: 'Challenge',         badge: '★★',        badgeStyle: 'bg-green-100 text-green-800', href: viewHref(`worksheets/measurement-geometry/${t.slug}/${t.wsSlug}-worksheet-challenge-v1`) },
          { label: 'Exit Tickets',      badge: 'Formative', badgeStyle: 'bg-slate-100 text-slate-700', href: viewHref(`exits/${t.slug}/${t.exitSlug}`) },
        ].map(item => (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${border} px-5 py-4 flex items-center justify-between gap-4`}>
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-slate-800">{item.label}</span>
              <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${item.badgeStyle}`}>{item.badge}</span>
            </div>
            <a href={item.href} class="flex-shrink-0 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
          </div>
        ))}
      </div>
      <details class="group">
        <summary class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-slate-400 hover:text-slate-600 transition-colors select-none">
          <span class="inline-block transition-transform group-open:rotate-90">▶</span> Show answer keys
        </summary>
        <div class="mt-2 space-y-2">
          {[
            { label: 'Notes Answer Key',          path: `notes/${t.slug}/${t.noteSlug.replace('-notes-v1','-notes-answers-v1')}` },
            { label: 'Core Worksheet Answer Key',  path: `worksheets/measurement-geometry/${t.slug}/${t.wsSlug}-worksheet-core-answers-v1` },
            { label: 'Challenge Answer Key',       path: `worksheets/measurement-geometry/${t.slug}/${t.wsSlug}-worksheet-challenge-answers-v1` },
          ].map(ak => (
            <div class="bg-slate-50 rounded-xl border border-slate-200 px-5 py-4 flex items-center justify-between gap-4">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-slate-600">{ak.label}</span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Answer Key</span>
              </div>
              <a href={viewHref(ak.path)} class="flex-shrink-0 text-sm font-semibold text-slate-500 hover:text-slate-800 border border-slate-200 hover:border-slate-400 px-4 py-1.5 rounded-lg transition-colors">Open</a>
            </div>
          ))}
        </div>
      </details>
    </section>
  ))}
</Math9Layout>
