  const x = randInt(0, 10), y = randInt(0, 10);
  return { question: `On a coordinate grid, the point (${x}, ${y}) means: move ___ on the x-axis and ___ on the y-axis. What values fill the blanks?`,
    answer: `${x}, ${y}`,
    solution: `(${x}, ${y})\nFirst value (${x}) → x-axis (horizontal, right)\nSecond value (${y}) → y-axis (vertical, up)`,
    hint: `The first number is always x (horizontal), the second is y (vertical).`,
    accept: i => { const p = i.split(/[,\s]+/).map(Number).filter(n=>!isNaN(n)); return p[0]===x && p[1]===y; }};
}
function genReadTable() {
  const data = Array.from({length: 4}, (_, i) => [i+1, randInt(2, 20)]);
  const idx = randInt(0, 3);
  return { question: `Table: ${data.map(d=>`x=${d[0]}→y=${d[1]}`).join(', ')}. What is y when x = ${data[idx][0]}?`,
    answer: `${data[idx][1]}`,
    solution: `Look up x = ${data[idx][0]} in the table.\ny = ${data[idx][1]}`,
    hint: `Find x = ${data[idx][0]} and read the y value next to it.`,
    accept: i => parseInt(i) === data[idx][1] };
}
function genIndepDepStats() {
  const scenarios = [
    { text: 'Hours of sleep vs. energy level the next day', ind: 'hours of sleep', dep: 'energy level' },
    { text: 'Amount of rainfall vs. height of grass', ind: 'rainfall', dep: 'height of grass' },
    { text: 'Age of a car vs. its resale value', ind: 'age', dep: 'resale value' },
  ];
  const s = scenarios[randInt(0, scenarios.length - 1)];
  return { question: `"${s.text}"\nWhich is the dependent variable?`, answer: s.dep,
    solution: `Independent (cause): ${s.ind}\nDependent (effect): ${s.dep}\nThe dependent variable responds to changes in the independent variable.`,
    hint: `The dependent variable is the one that responds or changes because of the other.`,
    accept: i => i.toLowerCase().includes(s.dep.split(' ')[0].toLowerCase()) };
}

// ─── GENERATORS: 11. Probability ───
function genListOutcomes() {
  const events = [
    { item: 'a standard die', outcomes: ['1','2','3','4','5','6'] },
    { item: 'a coin', outcomes: ['heads','tails'] },
    { item: 'a spinner with sections Red, Blue, Green', outcomes: ['Red','Blue','Green'] },
  ];
  const e = events[randInt(0, events.length - 1)];
  return { question: `List all possible outcomes when you roll/flip/spin ${e.item}.`, answer: e.outcomes.join(', '),
    solution: `All possible outcomes of ${e.item}:\n${e.outcomes.join(', ')}\nTotal: ${e.outcomes.length} outcomes`,
    hint: `Think of every possible result.`,
    accept: i => { const got = i.toLowerCase().split(/[,\s]+/).filter(Boolean).sort(); const exp = e.outcomes.map(o=>o.toLowerCase()).sort(); return JSON.stringify(got)===JSON.stringify(exp); }};
}
function genFavorableOutcomes() {
  const total = randInt(8, 20);
  const fav = randInt(1, total - 1);
  const items = ['red marbles', 'blue cards', 'winning tickets', 'green gumballs'];
  const item = items[randInt(0, items.length - 1)];
  return { question: `A bag has ${total} items. ${fav} are ${item}. How many favorable outcomes for drawing a ${item.replace(/s$/, '')}?`,
    answer: `${fav}`,
    solution: `Favorable outcomes = number of ${item}\n= ${fav}`,
    hint: `Favorable means the outcome you want.`,
    accept: i => parseInt(i) === fav };
}
function genProbFraction() {
  const total = randInt(6, 20), fav = randInt(1, total - 1);
  const [sn, sd] = simplify(fav, total);
  return { question: `A spinner has ${total} equal sections. ${fav} are blue. What is P(blue) as a simplified fraction?`,
    answer: `${sn}/${sd}`,
    solution: `P(blue) = favorable ÷ total\n= ${fav}/${total}\n= ${sn}/${sd} (simplified by dividing by ${gcd(fav,total)})`,
    hint: `P(event) = favorable outcomes ÷ total outcomes. Then simplify.`,
    accept: i => { const p = i.replace(/\s/g,'').split('/'); return p.length===2 && parseInt(p[0])===sn && parseInt(p[1])===sd; }};
}
function genFracToDecPercent() {
  const n = randInt(1, 9), d = randInt(n+1, 10);
  const dec = Math.round(n / d * 1000) / 1000;
  const pct = Math.round(dec * 100 * 10) / 10;
  const mode = randInt(0, 1);
  if (mode === 0) return { question: `Convert ${n}/${d} to a decimal (round to 3 places).`, answer: `${dec}`,
    solution: `${n}/${d}\n= ${n} ÷ ${d}\n= ${dec}`, hint: `Divide numerator by denominator.`,
    accept: i => Math.abs(parseFloat(i) - dec) < 0.005 };
  return { question: `Convert ${n}/${d} to a percent (round to 1 decimal place).`, answer: `${pct}%`,
    solution: `${n}/${d}\n= ${n} ÷ ${d} = ${dec}\n${dec} × 100 = ${pct}%`, hint: `Divide, then multiply by 100.`,
    accept: i => Math.abs(parseFloat(i.replace('%','')) - pct) < 0.15 };
}
function genSimplifyFrac() {
  const g = randInt(2, 7), n = randInt(1, 8), d = randInt(n+1, 10);
  const num = n*g, den = d*g;
  return { question: `Simplify: ${num}/${den}`, answer: `${n}/${d}`,
    solution: `GCF of ${num} and ${den} is ${g}\n${num} ÷ ${g} = ${n}\n${den} ÷ ${g} = ${d}\n= ${n}/${d}`,
    hint: `Find the GCF and divide both top and bottom.`,
    accept: i => { const p = i.replace(/\s/g,'').split('/'); return p.length===2 && parseInt(p[0])===n && parseInt(p[1])===d; }};
}
function genCountSystematic() {
  const shirts = randInt(2, 4), pants = randInt(2, 4);
  return { question: `You have ${shirts} shirts and ${pants} pants. How many different outfits can you make?`,
    answer: `${shirts * pants}`,
    solution: `Each shirt can pair with each pair of pants\n${shirts} shirts × ${pants} pants = ${shirts*pants} outfits`,
    hint: `Multiply the number of choices for each item.`,
    accept: i => parseInt(i) === shirts * pants };
}

