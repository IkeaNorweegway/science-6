}

// ─── NEW GENERATORS: Gap-filling (grade 9 level skills) ───
function genSqrtFraction() {
  const pairs = [[1,4],[1,9],[4,9],[9,16],[1,25],[4,25],[9,25],[16,25],[25,36],[49,64],[1,100],[9,100],[49,4],[64,9]];
  const [n, d] = pairs[randInt(0, pairs.length - 1)];
  const sn = Math.sqrt(n), sd = Math.sqrt(d);
  return { question: `Evaluate: √(${n}/${d})`, answer: `${sn}/${sd}`,
    solution: `√(${n}/${d})\n= √${n} / √${d}\n= ${sn}/${sd}${Number.isInteger(sn/sd) ? ' = '+(sn/sd) : ' ≈ '+(sn/sd).toFixed(3)}`,
    hint: 'Take the square root of the numerator and denominator separately.',
    accept: i => { const c=i.replace(/\s/g,''); return c===`${sn}/${sd}` || Math.abs(parseFloat(i)-sn/sd)<0.02; }};
}
function genEstimateSqrt() {
  const n = randInt(2, 99);
  const low = Math.floor(Math.sqrt(n)), high = low + 1;
  if (low * low === n) return genEstimateSqrt();
  const actual = Math.round(Math.sqrt(n) * 10) / 10;
  return { question: `Between which two consecutive whole numbers is √${n}? Also estimate to one decimal.`, answer: `${low} and ${high}, ≈ ${actual}`,
    solution: `${low}² = ${low*low} and ${high}² = ${high*high}\n${low*low} < ${n} < ${high*high}\nSo ${low} < √${n} < ${high}\n√${n} ≈ ${actual}`,
    hint: `Find two perfect squares that ${n} is between.`,
    accept: i => { const c=i.toLowerCase(); return (c.includes(`${low}`) && c.includes(`${high}`)) || Math.abs(parseFloat(i)-actual)<0.2; }};
}
function genPowerOfPower() {
  const b = randInt(2, 5), m = randInt(2, 3), n = randInt(2, 3);
  const inner = Math.pow(b, m), result = Math.pow(inner, n);
  return { question: `Simplify then evaluate: (${b}${m===2?'²':'³'})${n===2?'²':'³'}`, answer: `${result}`,
    solution: `(${b}${m===2?'²':'³'})${n===2?'²':'³'}\n= ${b}^(${m}×${n})\n= ${b}^${m*n}\n= ${result}\nOr: (${b}${m===2?'²':'³'})${n===2?'²':'³'} = (${inner})${n===2?'²':'³'} = ${result}`,
    hint: `Power of a power: multiply the exponents. Or evaluate the inner power first.`,
    accept: i => parseInt(i) === result };
}
