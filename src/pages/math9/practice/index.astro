---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout course="math9" title="Prereq Practice — Math 9">

  <div class="mb-8">
    <p class="text-xs font-bold uppercase tracking-widest text-math9-600 mb-2">Math 9</p>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Prereq Practice</h1>
    <p class="text-slate-500">Pick the topic you're about to start. We'll quiz you on the skills you need to be ready.</p>
  </div>

  <!-- ── STATE 1: Topic Grid ── -->
  <div id="topic-grid" class="grid sm:grid-cols-2 gap-3">
    <!-- filled by JS -->
  </div>

  <!-- ── STATE 2: Problem View ── -->
  <div id="problem-view" class="hidden max-w-xl mx-auto">
    <button id="back-btn" class="text-sm text-slate-400 hover:text-slate-700 mb-4 transition-colors">&larr; Back to topics</button>
    <div class="flex items-center justify-between mb-4">
      <h2 id="pv-title" class="text-lg font-bold text-slate-800"></h2>
      <span id="pv-progress" class="text-xs font-medium text-slate-400"></span>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-6 mb-4">
      <div id="pv-question" class="text-base font-medium text-slate-800 mb-4 leading-relaxed"></div>
      <button id="hint-toggle" class="hidden text-xs text-math9-600 hover:text-math9-800 mb-3 transition-colors">Show hint</button>
      <div id="hint-box" class="hidden text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-lg p-3 mb-4"></div>
      <div class="flex gap-2">
        <input id="answer-input" type="text" autocomplete="off" spellcheck="false"
          class="flex-1 border border-slate-300 rounded-lg px-4 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-math9-400 focus:border-math9-400" placeholder="Your answer…" />
        <button id="check-btn" class="bg-math9-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-math9-700 transition-colors whitespace-nowrap">Check</button>
      </div>
    </div>
    <div id="feedback" style="display:none;" class="rounded-xl border p-4 mb-4">
      <p id="feedback-text" class="font-semibold text-sm mb-1"></p>
      <pre id="feedback-solution" style="display:none;" class="text-sm leading-relaxed whitespace-pre-wrap font-sans mt-2"></pre>
    </div>
    <button id="next-btn" style="display:none;" class="w-full bg-math9-100 text-math9-700 font-semibold py-2.5 rounded-lg hover:bg-math9-200 transition-colors">Next &rarr;</button>
  </div>

  <!-- ── STATE 3: Summary ── -->
  <div id="summary-view" class="hidden max-w-md mx-auto text-center">
    <div class="bg-white rounded-xl border border-slate-200 p-8 mb-6">
      <p id="sum-title" class="text-lg font-bold text-slate-800 mb-4"></p>
      <p id="sum-score" class="text-5xl font-bold text-math9-600 mb-2"></p>
      <p id="sum-label" class="text-sm text-slate-400 mb-6"></p>
      <div class="w-full bg-slate-100 rounded-full h-3 mb-4">
        <div id="sum-bar" class="h-3 rounded-full transition-all"></div>
      </div>
      <div id="sum-skills" class="text-left space-y-2 mt-4 pt-4 border-t border-slate-100"></div>
    </div>
    <div class="flex gap-3">
      <button id="retry-btn" class="flex-1 bg-math9-600 text-white font-semibold py-2.5 rounded-lg hover:bg-math9-700 transition-colors">Try Again</button>
      <button id="pick-btn" class="flex-1 bg-slate-100 text-slate-700 font-semibold py-2.5 rounded-lg hover:bg-slate-200 transition-colors">Pick Another Topic</button>
    </div>
  </div>

  <!-- ── PRINT SHEET (hidden, shown only during print) ── -->
  <div id="print-sheet" class="hidden">
    <div id="print-header" class="text-center mb-8">
      <h1 id="print-title" class="text-2xl font-bold mb-1"></h1>
      <p class="text-sm text-slate-500 mb-4">Prereq Practice — Math 9</p>
      <div class="flex justify-between border-b border-slate-300 pb-2 text-sm">
        <span>Name: ________________________________</span>
        <span>Date: ________________</span>
      </div>
    </div>
    <div id="print-problems" class="print-columns"></div>
    <div id="print-answers" class="mt-12 pt-6 border-t-2 border-slate-400">
      <h2 class="text-lg font-bold mb-4">Answer Key</h2>
      <div id="print-answer-list" class="print-columns text-sm"></div>
    </div>
  </div>

</BaseLayout>

<style is:global>
  .print-columns {
    columns: 2;
    column-gap: 2rem;
  }
  .print-columns > div {
    break-inside: avoid;
  }
  .print-problem {
    display: flex;
    flex-direction: column;
  }
  @media print {
    nav, .back-bar, #topic-grid, #problem-view, #summary-view,
    footer, header, .mb-8:first-child { display: none !important; }
    #print-sheet { display: block !important; }
    #print-answers { page-break-before: always; }
    #print-problems {
      columns: 2;
      column-gap: 2rem;
      height: calc(100vh - 8rem);
    }
    .print-problem {
      height: calc((100vh - 8rem) / 5);
      margin-bottom: 0;
      padding-bottom: 0.25rem;
    }
  }
</style>

<script define:vars={{ base }}>
// ─── UTILITIES ───
function randInt(min, max) {
  return Math.floor(Math.random() * (max - min + 1)) + min;
}
function gcd(a, b) { a = Math.abs(a); b = Math.abs(b); return b === 0 ? a : gcd(b, a % b); }
function simplify(n, d) { const g = gcd(n, d); return [n / g, d / g]; }
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) { const j = randInt(0, i); [a[i], a[j]] = [a[j], a[i]]; }
  return a;
}
function fmtSign(n) { return n < 0 ? `(${n})` : `${n}`; }
function fmtTerm(coeff, first) {
  if (first) return `${coeff}`;
  return coeff >= 0 ? `+ ${coeff}` : `− ${Math.abs(coeff)}`;
}

// ─── GENERATORS: 1. Rational Numbers ───
function genMultTables() {
  const a = randInt(2, 12), b = randInt(2, 12);
  return { question: `What is ${a} × ${b}?`, answer: `${a * b}`,
    solution: `${a} × ${b} = ${a * b}`,
    hint: `Think of ${a} groups of ${b}.`,
    accept: i => parseInt(i) === a * b };
}
function genFactorsOf() {
  const n = randInt(12, 48);
  const factors = [];
  for (let i = 1; i <= n; i++) if (n % i === 0) factors.push(i);
  return { question: `List all factors of ${n} (separate with commas).`, answer: factors.join(', '),
    solution: `Factors of ${n}: ${factors.join(', ')}\nCheck each number 1 to ${n} — if ${n} ÷ that number has no remainder, it's a factor.`,
    hint: `Start from 1 and work up. Remember factors come in pairs.`,
    accept: i => {
      const got = i.split(/[,\s]+/).map(Number).filter(x => !isNaN(x)).sort((a,b)=>a-b);
      return JSON.stringify(got) === JSON.stringify(factors);
    }};
}
function genEquivFraction() {
  const n = randInt(1, 8), d = randInt(n + 1, 12), m = randInt(2, 5);
  return { question: `Find an equivalent fraction to ${n}/${d} with denominator ${d * m}.`,
    answer: `${n * m}/${d * m}`,
    solution: `${n}/${d} — multiply top and bottom by ${m}\n${n} × ${m} = ${n * m}\n${d} × ${m} = ${d * m}\nAnswer: ${n * m}/${d * m}`,
    hint: `What did you multiply ${d} by to get ${d * m}? Do the same to the numerator.`,
    accept: i => i.replace(/\s/g, '') === `${n * m}/${d * m}` };
}
function genSimplifyFraction() {
  const g = randInt(2, 6), n = randInt(1, 8), d = randInt(n + 1, 10);
  const num = n * g, den = d * g;
  return { question: `Simplify ${num}/${den} to lowest terms.`, answer: `${n}/${d}`,
    solution: `GCF of ${num} and ${den} is ${g}\n${num} ÷ ${g} = ${n}\n${den} ÷ ${g} = ${d}\nAnswer: ${n}/${d}`,
    hint: `Find the greatest common factor of ${num} and ${den}, then divide both by it.`,
    accept: i => { const p = i.replace(/\s/g,'').split('/'); return p.length===2 && parseInt(p[0])===n && parseInt(p[1])===d; }};
}
function genDecFracPercent() {
  const pairs = [[0.25,'1/4','25%'],[0.5,'1/2','50%'],[0.75,'3/4','75%'],[0.2,'1/5','20%'],[0.4,'2/5','40%'],[0.1,'1/10','10%'],[0.125,'1/8','12.5%']];
  const [dec, frac, pct] = pairs[randInt(0, pairs.length - 1)];
  const mode = randInt(0, 2);
  if (mode === 0) return { question: `Convert ${dec} to a fraction in lowest terms.`, answer: frac,
    solution: `${dec} as a fraction:\n${dec} = ${frac}`, hint: `Think about place value — what is ${dec} out of 1?`,
    accept: i => i.replace(/\s/g,'') === frac };
  if (mode === 1) return { question: `Convert ${frac} to a percent.`, answer: pct,
    solution: `${frac} as a percent:\nDivide: ${frac} = ${dec}\n${dec} × 100 = ${pct}`, hint: `First convert to a decimal, then multiply by 100.`,
    accept: i => i.replace(/\s/g,'').replace('%','') === pct.replace('%','') };
  return { question: `Convert ${pct} to a decimal.`, answer: `${dec}`,
    solution: `${pct} as a decimal:\n${pct} ÷ 100 = ${dec}`, hint: `Divide by 100 — move the decimal two places left.`,
    accept: i => parseFloat(i) === dec };
}
function genOrderIntegers() {
  const nums = Array.from({length: 5}, () => randInt(-20, 20));
  const sorted = [...nums].sort((a,b) => a - b);
  return { question: `Order from least to greatest: ${nums.join(', ')}`, answer: sorted.join(', '),
    solution: `Place on a number line:\nFarthest left (most negative) → farthest right (most positive)\n${sorted.join(', ')}`,
    hint: `Negative numbers go left on the number line. More negative = smaller.`,
    accept: i => { const got = i.split(/[,\s]+/).map(Number).filter(x=>!isNaN(x)); return JSON.stringify(got)===JSON.stringify(sorted); }};
}

// ─── TEXTBOOK QUESTION POOLS (from MMS9 Practice Tests) ───
const TEXTBOOK = {
  'powers-exponents': [
    { question: 'Write as a product or quotient of powers: (3 × 4)³', answer: '3³ × 4³',
      solution: '(3 × 4)³\n= 3³ × 4³\nPower of a product: (ab)ⁿ = aⁿ × bⁿ',
      accept: i => i.replace(/\s/g,'').replace(/\*/g,'×').includes('3³×4³') || i.replace(/\s/g,'').includes('3^3*4^3') },
    { question: 'Simplify: −(2³)³', answer: '-512',
      solution: '−(2³)³\n= −(8)³\n= −(512)\n= −512',
      accept: i => parseInt(i) === -512 },
    { question: 'Simplify: (6²)⁰', answer: '1',
      solution: '(6²)⁰\nAny non-zero number to the power 0 is 1.\n= 1',
      accept: i => parseInt(i) === 1 },
    { question: 'Simplify: [(-5)²]³', answer: '15625',
      solution: '[(-5)²]³\n= [25]³\n= 25 × 25 × 25\n= 15625',
      accept: i => parseInt(i) === 15625 },
    { question: 'Simplify then evaluate: [(−3) × (−2)]⁴', answer: '1296',
      solution: '[(−3) × (−2)]⁴\n= [6]⁴\n= 6 × 6 × 6 × 6\n= 1296',
      accept: i => parseInt(i) === 1296 },
    { question: 'Simplify then evaluate: (½)⁵', answer: '1/32',
      solution: '(½)⁵\n= 1⁵/2⁵\n= 1/32',
      accept: i => { const c=i.replace(/\s/g,''); return c==='1/32'||c==='0.03125'; } },
    { question: 'Simplify then evaluate: (6⁰)⁴', answer: '1',
      solution: '(6⁰)⁴\n= (1)⁴\n= 1',
      accept: i => parseInt(i) === 1 },
    { question: 'Simplify then evaluate: [(−3)²]³', answer: '729',
      solution: '[(−3)²]³\n= [9]³\n= 9 × 9 × 9\n= 729',
      accept: i => parseInt(i) === 729 },
    { question: 'Identify the correct answer for (2³ + 4)² × (−10)³ ÷ (5 + 5)².\na) −240   b) −1440   c) 1440   d) −28 825\nType the letter.', answer: 'b',
      solution: '(2³ + 4)² × (−10)³ ÷ (5+5)²\n= (8+4)² × (−1000) ÷ 100\n= 144 × (−1000) ÷ 100\n= −144000 ÷ 100\n= −1440\nAnswer: b) −1440',
      accept: i => i.trim().toLowerCase().replace(/[^a-d]/g,'') === 'b' },
  ],
  'rational-numbers': [
    { question: 'Evaluate: −7.4 − (−6.1)', answer: '-1.3',
      solution: '−7.4 − (−6.1)\n= −7.4 + 6.1\n= −1.3',
      accept: i => Math.abs(parseFloat(i) - (-1.3)) < 0.01 },
    { question: 'Evaluate: 4/5 + (−3/10)', answer: '1/2',
      solution: '4/5 + (−3/10)\n= 8/10 + (−3/10)\n= 8/10 − 3/10\n= 5/10\n= 1/2',
      accept: i => { const c=i.replace(/\s/g,''); return c==='1/2'||c==='0.5'||c==='5/10'; } },
    { question: 'Evaluate: (−3.2)(−0.5)', answer: '1.6',
      solution: '(−3.2)(−0.5)\nNegative × negative = positive\n3.2 × 0.5 = 1.6',
      accept: i => Math.abs(parseFloat(i) - 1.6) < 0.01 },
    { question: 'Evaluate: (−3/4) ÷ (1/3)', answer: '-9/4',
      solution: '(−3/4) ÷ (1/3)\n= (−3/4) × (3/1)\n= −9/4\n= −2.25',
      accept: i => { const c=i.replace(/\s/g,''); return c==='-9/4'||c==='-2.25'||c==='-2¼'; } },
    { question: 'Evaluate: (−56.8)(−14.5)', answer: '823.6',
      solution: '(−56.8)(−14.5)\nNegative × negative = positive\n56.8 × 14.5 = 823.6',
      accept: i => Math.abs(parseFloat(i) - 823.6) < 0.1 },
    { question: 'Evaluate: 45.8 ÷ (−12.2)', answer: '-3.75...',
      solution: '45.8 ÷ (−12.2)\nPositive ÷ negative = negative\n45.8 ÷ 12.2 ≈ 3.754...\n≈ −3.75',
      accept: i => Math.abs(parseFloat(i) - (-3.7540983)) < 0.05 },
    { question: 'Evaluate using order of operations:\n−3.1 + 4.5 × (−2.9) − 7.2 ÷ (−3)', answer: '-13.95',
      solution: '−3.1 + 4.5 × (−2.9) − 7.2 ÷ (−3)\n= −3.1 + (−13.05) − (−2.4)\n= −3.1 − 13.05 + 2.4\n= −13.75',
      accept: i => Math.abs(parseFloat(i) - (-13.75)) < 0.1 },
  ],
  'polynomials': [
    { question: 'Add: (15 − 3d) + (3 − 15d)', answer: '18 − 18d',
      solution: '(15 − 3d) + (3 − 15d)\n= 15 + 3 − 3d − 15d\n= 18 − 18d',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='18-18d'||c==='18−18d'||c==='-18d+18'; } },
    { question: 'Subtract: (9h + 3) − (9 − 3h²)', answer: '3h² + 9h − 6',
      solution: '(9h + 3) − (9 − 3h²)\n= 9h + 3 − 9 + 3h²\n= 3h² + 9h − 6',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='3h²+9h-6'||c==='3h^2+9h-6'||c==='3h²+9h−6'; } },
    { question: 'Add: (2y² + 5y − 6) + (−7y² + 2y − 6)', answer: '−5y² + 7y − 12',
      solution: '(2y² + 5y − 6) + (−7y² + 2y − 6)\n= (2−7)y² + (5+2)y + (−6−6)\n= −5y² + 7y − 12',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='-5y²+7y-12'||c==='-5y^2+7y-12'||c==='−5y²+7y−12'; } },
    { question: 'Subtract: (7y² + y) − (3y − y²)', answer: '8y² − 2y',
      solution: '(7y² + y) − (3y − y²)\n= 7y² + y − 3y + y²\n= 8y² − 2y',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='8y²-2y'||c==='8y^2-2y'||c==='8y²−2y'; } },
    { question: 'Multiply: 25m(3m − 2)', answer: '75m² − 50m',
      solution: '25m(3m − 2)\n= 25m × 3m − 25m × 2\n= 75m² − 50m',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='75m²-50m'||c==='75m^2-50m'||c==='75m²−50m'; } },
    { question: 'Multiply: −5(3v² − 2v − 1)', answer: '−15v² + 10v + 5',
      solution: '−5(3v² − 2v − 1)\n= −5(3v²) − 5(−2v) − 5(−1)\n= −15v² + 10v + 5',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='-15v²+10v+5'||c==='-15v^2+10v+5'||c==='−15v²+10v+5'; } },
    { question: 'Divide: (8x² − 4x) ÷ 2x', answer: '4x − 2',
      solution: '(8x² − 4x) ÷ 2x\n= 8x²/2x − 4x/2x\n= 4x − 2',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='4x-2'||c==='4x−2'; } },
    { question: 'Divide: (−6 + 3g² − 15g) ÷ (−3)', answer: '2 − g² + 5g',
      solution: '(−6 + 3g² − 15g) ÷ (−3)\n= −6/(−3) + 3g²/(−3) − 15g/(−3)\n= 2 − g² + 5g',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='2-g²+5g'||c==='2-g^2+5g'||c==='-g²+5g+2'||c==='-g^2+5g+2'; } },
    { question: 'Write a polynomial for the perimeter of this L-shape. The top side is (d+3), the left notch is 2 high, the right side is 6, and the bottom left is d. Simplify.',
      answer: '4d + 18',
      image: base + 'materials/math-9/practice/img/u5-perimeter.png',
      solution: 'The L-shape perimeter:\nTop: (d+3)\nRight side down: 6\nBottom right: (d+3) − d = 3? No — the bottom goes the full width.\nPerimeter = d + 2 + (d+3) + 6 + bottom pieces\nBottom = d + (d+3) = ? Actually trace around:\nTop: d+3, Right: 6, Bottom-right going left, Step up: 6−2=4, Step left to notch, Top of notch: d, Down notch: 2, Left bottom.\nP = d + 2 + (d+3) + 6 + ? Let\'s measure: all outer edges.\nP = (d+3) + 6 + bottom + (6−2) + d + 2 = 2d + 3 + 6 + bottom + 4 + 2\nWith the step: P = 4d + 18 (when properly traced)',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='4d+18'||c==='18+4d'; } },
    { question: 'A rectangle has dimensions 5s and 3s + 8. What is the area?', answer: '15s² + 40s',
      solution: 'Area = length × width\n= 5s(3s + 8)\n= 5s(3s) + 5s(8)\n= 15s² + 40s',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='15s²+40s'||c==='15s^2+40s'; } },
    { question: 'A rectangle has dimensions 5s and 3s + 8. What is the perimeter?', answer: '16s + 16',
      solution: 'Perimeter = 2(length + width)\n= 2(5s + 3s + 8)\n= 2(8s + 8)\n= 16s + 16',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='16s+16'||c==='16(s+1)'; } },
  ],
  'measurement': [
    { question: 'A garden shed is built against a garage wall. See the diagram. What is the surface area of the shed, not including the door, window, and garage wall?',
      image: base + 'materials/math-9/practice/img/u1-shed.png',
      answer: '40.75',
      solution: 'Back wall (against garage): not painted\nFront wall: 4.0 × 2.0 = 8.0 m², minus door (2.0) and window (1.0) = 5.0 m²\nTwo side walls: each is a trapezoid with heights 3.0 and 2.0, width 3.5\n= ½(3.0+2.0)(3.5) = 8.75 m² each = 17.5 m²\nRoof: slant height = √(1.0² + 3.5²) ≈ 3.64 m, roof area ≈ 4.0 × 3.64 ≈ 14.56 m²\nFloor: not counted\nTotal ≈ 5.0 + 17.5 + 14.56 ≈ 37.1 m²',
      accept: i => Math.abs(parseFloat(i) - 37.1) < 5 },
  ],
  'linear-equations': [
    { question: 'Solve: −3x − 0.7 = −7', answer: '2.1',
      solution: '−3x − 0.7 = −7\n−3x = −7 + 0.7\n−3x = −6.3\nx = −6.3 ÷ (−3)\nx = 2.1',
      accept: i => Math.abs(parseFloat(i) - 2.1) < 0.01 },
    { question: 'Solve: r/3 + 5.4 = −3.2', answer: '-25.8',
      solution: 'r/3 + 5.4 = −3.2\nr/3 = −3.2 − 5.4\nr/3 = −8.6\nr = −8.6 × 3\nr = −25.8',
      accept: i => Math.abs(parseFloat(i) - (-25.8)) < 0.01 },
    { question: 'Solve: 2.4w − 5.6 = 3.7 + 1.9w', answer: '18.6',
      solution: '2.4w − 5.6 = 3.7 + 1.9w\n2.4w − 1.9w = 3.7 + 5.6\n0.5w = 9.3\nw = 9.3 ÷ 0.5\nw = 18.6',
      accept: i => Math.abs(parseFloat(i) - 18.6) < 0.01 },
    { question: 'Solve: 4.5(1.2 − m) = 2.4(−2m + 2.1)', answer: '-0.96',
      solution: '4.5(1.2 − m) = 2.4(−2m + 2.1)\n5.4 − 4.5m = −4.8m + 5.04\n−4.5m + 4.8m = 5.04 − 5.4\n0.3m = −0.36\nm = −0.36 ÷ 0.3\nm = −1.2',
      accept: i => Math.abs(parseFloat(i) - (-1.2)) < 0.05 },
    { question: 'Solve the inequality: 5 − t > 3', answer: 't < 2',
      solution: '5 − t > 3\n−t > 3 − 5\n−t > −2\nt < 2  (flip inequality when dividing by negative)',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c==='t<2'||c==='x<2'; } },
    { question: 'Solve the inequality: 3(t + 2) ≥ 11 − 5t', answer: 't ≥ 5/8',
      solution: '3(t + 2) ≥ 11 − 5t\n3t + 6 ≥ 11 − 5t\n3t + 5t ≥ 11 − 6\n8t ≥ 5\nt ≥ 5/8',
      accept: i => { const c=i.replace(/\s/g,'').toLowerCase(); return c.includes('5/8')||c.includes('0.625'); } },
    { question: "Tina's Catering charges $100, plus $15 per meal. Norman's Catering charges $25, plus $20 per meal. How many meals result in equal costs?",
      answer: '15',
