  if (mode === 1) { const c = randInt(-8, 8); return { question: `Is the line y = ${c} vertical, horizontal, or oblique?`, answer: 'horizontal', solution: `y = ${c}\nThis is a horizontal line — all points have y = ${c}.`, hint: 'x = constant is vertical, y = constant is horizontal.', accept: i => i.toLowerCase().includes('horizontal') }; }
