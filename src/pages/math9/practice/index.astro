// ─── APP STATE ───
let currentTopic = null;
let problems = [];
let currentIndex = 0;
let score = 0;
let answered = false;

// ─── DOM REFS ───
const topicGrid = document.getElementById('topic-grid');
const problemView = document.getElementById('problem-view');
const summaryView = document.getElementById('summary-view');
const backBtn = document.getElementById('back-btn');
const pvTitle = document.getElementById('pv-title');
const pvProgress = document.getElementById('pv-progress');
const pvQuestion = document.getElementById('pv-question');
const hintToggle = document.getElementById('hint-toggle');
const hintBox = document.getElementById('hint-box');
const answerInput = document.getElementById('answer-input');
const checkBtn = document.getElementById('check-btn');
const feedback = document.getElementById('feedback');
const feedbackText = document.getElementById('feedback-text');
const feedbackSolution = document.getElementById('feedback-solution');
const nextBtn = document.getElementById('next-btn');
const sumTitle = document.getElementById('sum-title');
const sumScore = document.getElementById('sum-score');
const sumLabel = document.getElementById('sum-label');
const sumBar = document.getElementById('sum-bar');
const retryBtn = document.getElementById('retry-btn');
const pickBtn = document.getElementById('pick-btn');

// ─── localStorage ───
const STORAGE_KEY = 'math9-practice-progress';
const SKILLS_KEY = 'math9-practice-skills';
function loadProgress() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch { return {}; } }
function saveProgress(topicId, s, total) {
  const prog = loadProgress();
  const prev = prog[topicId] || { best: 0, attempts: 0 };
  prog[topicId] = { best: Math.max(prev.best, s), attempts: prev.attempts + 1, lastDate: new Date().toISOString().slice(0,10) };
  localStorage.setItem(STORAGE_KEY, JSON.stringify(prog));
}
function loadSkills() { try { return JSON.parse(localStorage.getItem(SKILLS_KEY)) || {}; } catch { return {}; } }
function recordSkill(skillId, correct) {
  const skills = loadSkills();
  const prev = skills[skillId] || { correct: 0, total: 0 };
  prev.total++;
  if (correct) prev.correct++;
  skills[skillId] = prev;
  localStorage.setItem(SKILLS_KEY, JSON.stringify(skills));
}
function skillStatus(skillId) {
  const skills = loadSkills();
  const s = skills[skillId];
  if (!s || s.total === 0) return 'new';
  const rate = s.correct / s.total;
  if (rate >= 0.8 && s.total >= 2) return 'mastered';
  if (rate >= 0.5) return 'developing';
  return 'needs-work';
}
function skillId(topicId, skillName) { return topicId + '::' + skillName; }

// ─── RENDER TOPIC GRID ───
const statusDot = { mastered: '🟢', developing: '🟡', 'needs-work': '🔴', 'new': '⚪' };
const statusLabel = { mastered: 'Mastered', developing: 'Developing', 'needs-work': 'Needs work', 'new': '' };

function renderGrid() {
  const prog = loadProgress();
  topicGrid.innerHTML = TOPICS.map(t => {
    const p = prog[t.id];
    const badge = p ? `<span class="text-xs font-semibold ${p.best>=4?'text-emerald-600':'text-slate-400'}">Best: ${p.best}/5</span>` : '';
    const skillDots = t.skills.map(s => {
      const st = skillStatus(skillId(t.id, s.name));
      return `<span title="${s.name}: ${statusLabel[st] || 'Not tried'}" style="cursor:default;">${statusDot[st]}</span>`;
    }).join(' ');
    return `<button data-topic="${t.id}" class="text-left bg-white rounded-xl border border-slate-200 border-l-4 border-l-indigo-400 px-5 py-4 hover:bg-indigo-50 transition-colors group">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-bold text-indigo-400">Topic ${t.num}</span>
        ${badge}
      </div>
      <p class="font-bold text-slate-800 text-sm mb-1 group-hover:text-indigo-700 transition-colors">${t.name}</p>
      <p class="text-xs text-slate-400 mb-2">${t.summary}</p>
      <div class="text-xs mb-2">${skillDots}</div>
      <div class="flex gap-2">
        <span class="text-xs font-semibold text-indigo-600 group-hover:underline">Start Practice →</span>
        <button data-print="${t.id}" class="text-xs font-medium text-slate-400 hover:text-slate-700 ml-auto">🖨 Print</button>
      </div>
    </button>`;
  }).join('');
}

// ─── GENERATE PROBLEM SET ───
function generateProblems(topic) {
  const skillList = topic.skills.length > 5 ? shuffle(topic.skills).slice(0, 5) : [...topic.skills];
  return skillList.map(s => {
    for (let i = 0; i < 10; i++) {
      try {
        const p = s.gen();
        if (!p) continue;
        p._skill = s.name;
        return p;
      } catch {}
    }
    const fallback = topic.skills.find(sk => sk.name !== 'Textbook problems');
    const p = fallback ? fallback.gen() : s.gen();
    p._skill = fallback ? fallback.name : s.name;
    return p;
  });
}

// ─── SHOW/HIDE STATES ───
function showState(state) {
  topicGrid.classList.toggle('hidden', state !== 'grid');
  topicGrid.classList.toggle('sm:grid-cols-2', state === 'grid');
  topicGrid.classList.toggle('grid', state === 'grid');
  problemView.classList.toggle('hidden', state !== 'problem');
  summaryView.classList.toggle('hidden', state !== 'summary');
}

// ─── SELECT TOPIC ───
function selectTopic(topicId) {
  currentTopic = TOPICS.find(t => t.id === topicId);
  if (!currentTopic) return;
  problems = generateProblems(currentTopic);
  currentIndex = 0;
  score = 0;
  showState('problem');
  pvTitle.textContent = currentTopic.name;
  showProblem();
}

// ─── SHOW PROBLEM ───
function showProblem() {
  answered = false;
  const p = problems[currentIndex];
  pvProgress.textContent = `Problem ${currentIndex + 1} of ${problems.length}  ·  ${score} correct`;
  pvQuestion.innerHTML = p.question.replace(/\n/g, '<br>') + (p.image ? `<img src="${p.image}" alt="diagram" style="max-width:100%;margin-top:0.75rem;border-radius:0.5rem;border:1px solid #e2e8f0;">` : '');
  answerInput.value = '';
  answerInput.disabled = false;
  checkBtn.disabled = false;
  checkBtn.classList.remove('opacity-50');
  feedback.style.display = 'none';
  feedbackSolution.style.display = 'none';
  nextBtn.style.display = 'none';
  if (p.hint) {
    hintToggle.classList.remove('hidden');
    hintToggle.textContent = 'Show hint';
    hintBox.classList.add('hidden');
    hintBox.textContent = p.hint;
  } else {
    hintToggle.classList.add('hidden');
    hintBox.classList.add('hidden');
  }
  setTimeout(() => answerInput.focus(), 50);
}

// ─── CHECK ANSWER ───
function checkAnswer() {
  if (answered) return;
  const p = problems[currentIndex];
  const input = answerInput.value.trim();
  if (!input) return;
  answered = true;
  answerInput.disabled = true;
  checkBtn.disabled = true;
  checkBtn.classList.add('opacity-50');

  let correct = false;
  if (p.accept) {
    correct = p.accept(input);
  } else {
    correct = input.toLowerCase().replace(/\s+/g,' ') === p.answer.toLowerCase().replace(/\s+/g,' ');
  }

  if (p._skill && currentTopic) {
    recordSkill(skillId(currentTopic.id, p._skill), correct);
  }

  if (correct) {
    score++;
    feedback.className = 'rounded-xl border border-emerald-200 bg-emerald-50 p-4 mb-4';
    feedback.style.display = 'block';
    feedbackText.className = 'font-semibold text-sm text-emerald-700';
    feedbackText.textContent = 'Correct!';
    feedbackSolution.style.display = 'none';
    pvProgress.textContent = `Problem ${currentIndex + 1} of ${problems.length}  ·  ${score} correct`;
  } else {
    feedback.className = 'rounded-xl border border-red-200 bg-red-50 p-4 mb-4';
    feedback.style.display = 'block';
    feedbackText.className = 'font-semibold text-sm text-red-700 mb-1';
    feedbackText.textContent = `Not quite — the answer is ${p.answer}`;
    feedbackSolution.textContent = p.solution;
    feedbackSolution.style.display = 'block';
  }
  nextBtn.style.display = 'block';
  nextBtn.focus();
}

// ─── NEXT / SUMMARY ───
function nextProblem() {
  currentIndex++;
  if (currentIndex >= problems.length) {
    showSummary();
  } else {
    showProblem();
  }
}

function showSummary() {
  saveProgress(currentTopic.id, score, problems.length);
  showState('summary');
  sumTitle.textContent = currentTopic.name;
  sumScore.textContent = `${score} / ${problems.length}`;
  sumLabel.textContent = score === problems.length ? 'Perfect! You\'re ready.' : score >= 3 ? 'Good work — review the ones you missed.' : 'Keep practicing — you\'ll get there!';
  const pct = (score / problems.length) * 100;
  sumBar.style.width = `${pct}%`;
  sumBar.className = `h-3 rounded-full transition-all ${pct >= 80 ? 'bg-emerald-500' : pct >= 60 ? 'bg-amber-400' : 'bg-red-400'}`;

  const sumSkills = document.getElementById('sum-skills');
  sumSkills.innerHTML = '<p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">Skill Tracker</p>' +
    currentTopic.skills.map(s => {
      const sid = skillId(currentTopic.id, s.name);
      const st = skillStatus(sid);
      const data = loadSkills()[sid];
      const info = data ? `${data.correct}/${data.total} correct` : 'Not tried';
      return `<div class="flex items-center justify-between gap-2 text-sm">
        <span class="flex items-center gap-2"><span>${statusDot[st]}</span> ${s.name}</span>
        <span class="text-xs text-slate-400">${info}</span>
      </div>`;
    }).join('');
}

// ─── PRINT ───
function printWorksheet(topicId) {
  const topic = TOPICS.find(t => t.id === topicId);
  if (!topic) return;
  const printProblems = [];
  const skills = [...topic.skills];
  for (let round = 0; round < 2; round++) {
    for (const s of skills) {
      if (printProblems.length >= 10) break;
      for (let attempt = 0; attempt < 10; attempt++) {
        try { printProblems.push(s.gen()); break; } catch {}
      }
    }
  }

  document.getElementById('print-title').textContent = `Prereq Practice — ${topic.name}`;
  document.getElementById('print-problems').innerHTML = printProblems.map((p, i) =>
    `<div class="print-problem">
      <div class="flex gap-2 mb-1">
        <span class="font-bold text-slate-400 flex-shrink-0">${i+1}.</span>
        <p class="text-sm">${p.question}</p>
      </div>
      <div style="border:1px solid #cbd5e1; border-radius:0.5rem; flex:1; min-height:2rem;"></div>
    </div>`
  ).join('');
  document.getElementById('print-answer-list').innerHTML = printProblems.map((p, i) =>
    `<div class="flex gap-2 mb-4">
      <span class="font-bold text-slate-400 flex-shrink-0">${i+1}.</span>
      <div class="flex-1">
        <p class="font-medium text-sm mb-1">Answer: ${p.answer}</p>
        <pre class="text-xs text-slate-500 whitespace-pre-wrap font-sans">${p.solution}</pre>
      </div>
    </div>`
  ).join('');

  document.getElementById('print-sheet').classList.remove('hidden');
  window.print();
  document.getElementById('print-sheet').classList.add('hidden');
}

// ─── EVENT LISTENERS ───
topicGrid.addEventListener('click', e => {
  const printBtn = e.target.closest('[data-print]');
  if (printBtn) { printWorksheet(printBtn.dataset.print); return; }
  const card = e.target.closest('[data-topic]');
  if (card) selectTopic(card.dataset.topic);
});
backBtn.addEventListener('click', () => { showState('grid'); renderGrid(); });
checkBtn.addEventListener('click', checkAnswer);
answerInput.addEventListener('keydown', e => { if (e.key === 'Enter') { if (answered) nextProblem(); else checkAnswer(); } });
nextBtn.addEventListener('click', nextProblem);
retryBtn.addEventListener('click', () => selectTopic(currentTopic.id));
pickBtn.addEventListener('click', () => { showState('grid'); renderGrid(); });
hintToggle.addEventListener('click', () => {
  const showing = !hintBox.classList.contains('hidden');
  hintBox.classList.toggle('hidden');
  hintToggle.textContent = showing ? 'Show hint' : 'Hide hint';
});

// ─── INIT ───
renderGrid();
</script>
