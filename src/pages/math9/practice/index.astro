function genFactorPairs() {
  const n = randInt(12, 50);
  const pairs = [];
  for (let i = 1; i * i <= n; i++) if (n % i === 0) pairs.push(`${i} × ${n/i}`);
  return { question: `List all factor pairs of ${n} (e.g. "1 × ${n}, 2 × ...").`, answer: pairs.join(', '),
    solution: `Factor pairs of ${n}:\n${pairs.join('\n')}`,
    hint: `Start from 1 × ${n} and work inward.`,
    accept: i => {
      const got = i.split(/[,;]+/).map(s => s.trim().split(/\s*[×x*]\s*/).map(Number).sort((a,b)=>a-b)).sort((a,b)=>a[0]-b[0]);
      const exp = pairs.map(s => s.split(' × ').map(Number).sort((a,b)=>a-b)).sort((a,b)=>a[0]-b[0]);
      return JSON.stringify(got) === JSON.stringify(exp);
    }};
}
