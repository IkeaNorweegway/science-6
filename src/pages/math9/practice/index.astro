---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout course="math9" title="Prereq Practice — Math 9">

  <div class="mb-8">
    <p class="text-xs font-bold uppercase tracking-widest text-math9-600 mb-2">Math 9</p>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Prereq Practice</h1>
    <p class="text-slate-500">Pick the topic you're about to start. We'll quiz you on the skills you need to be ready.</p>
  </div>

  <!-- ── STATE 1: Topic Grid ── -->
  <div id="topic-grid" class="grid sm:grid-cols-2 gap-3">
    <!-- filled by JS -->
  </div>

  <!-- ── STATE 2: Problem View ── -->
  <div id="problem-view" class="hidden max-w-xl mx-auto">
    <button id="back-btn" class="text-sm text-slate-400 hover:text-slate-700 mb-4 transition-colors">&larr; Back to topics</button>
    <div class="flex items-center justify-between mb-4">
      <h2 id="pv-title" class="text-lg font-bold text-slate-800"></h2>
      <span id="pv-progress" class="text-xs font-medium text-slate-400"></span>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-6 mb-4">
      <p id="pv-question" class="text-base font-medium text-slate-800 mb-4 leading-relaxed"></p>
      <button id="hint-toggle" class="hidden text-xs text-math9-600 hover:text-math9-800 mb-3 transition-colors">Show hint</button>
      <div id="hint-box" class="hidden text-sm text-slate-500 bg-slate-50 border border-slate-200 rounded-lg p-3 mb-4"></div>
      <div class="flex gap-2">
        <input id="answer-input" type="text" autocomplete="off" spellcheck="false"
          class="flex-1 border border-slate-300 rounded-lg px-4 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-math9-400 focus:border-math9-400" placeholder="Your answer…" />
        <button id="check-btn" class="bg-math9-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-math9-700 transition-colors whitespace-nowrap">Check</button>
      </div>
    </div>
    <div id="feedback" class="hidden rounded-xl border p-4 mb-4">
      <p id="feedback-text" class="font-semibold text-sm mb-1"></p>
      <pre id="feedback-solution" class="hidden text-sm leading-relaxed whitespace-pre-wrap font-sans mt-2"></pre>
    </div>
    <button id="next-btn" class="hidden w-full bg-math9-100 text-math9-700 font-semibold py-2.5 rounded-lg hover:bg-math9-200 transition-colors">Next &rarr;</button>
  </div>

  <!-- ── STATE 3: Summary ── -->
  <div id="summary-view" class="hidden max-w-md mx-auto text-center">
    <div class="bg-white rounded-xl border border-slate-200 p-8 mb-6">
      <p id="sum-title" class="text-lg font-bold text-slate-800 mb-4"></p>
      <p id="sum-score" class="text-5xl font-bold text-math9-600 mb-2"></p>
      <p id="sum-label" class="text-sm text-slate-400 mb-6"></p>
      <div class="w-full bg-slate-100 rounded-full h-3 mb-6">
        <div id="sum-bar" class="h-3 rounded-full transition-all"></div>
      </div>
    </div>
    <div class="flex gap-3">
      <button id="retry-btn" class="flex-1 bg-math9-600 text-white font-semibold py-2.5 rounded-lg hover:bg-math9-700 transition-colors">Try Again</button>
      <button id="pick-btn" class="flex-1 bg-slate-100 text-slate-700 font-semibold py-2.5 rounded-lg hover:bg-slate-200 transition-colors">Pick Another Topic</button>
    </div>
  </div>

  <!-- ── PRINT SHEET (hidden, shown only during print) ── -->
  <div id="print-sheet" class="hidden">
    <div id="print-header" class="text-center mb-8">
      <h1 id="print-title" class="text-2xl font-bold mb-1"></h1>
      <p class="text-sm text-slate-500 mb-4">Prereq Practice — Math 9</p>
      <div class="flex justify-between border-b border-slate-300 pb-2 text-sm">
        <span>Name: ________________________________</span>
        <span>Date: ________________</span>
      </div>
    </div>
    <div id="print-problems" class="space-y-6"></div>
    <div id="print-answers" class="mt-12 pt-6 border-t-2 border-slate-400">
      <h2 class="text-lg font-bold mb-4">Answer Key</h2>
      <div id="print-answer-list" class="space-y-4 text-sm"></div>
    </div>
  </div>

</BaseLayout>

<style is:global>
  @media print {
    nav, .back-bar, #topic-grid, #problem-view, #summary-view,
    footer, header, .mb-8:first-child { display: none !important; }
    #print-sheet { display: block !important; }
    #print-answers { page-break-before: always; }
  }
</style>

<script define:vars={{ base }}>
// ─── UTILITIES ───
function randInt(min, max) {
  return Math.floor(Math.random() * (max - min + 1)) + min;
}
function gcd(a, b) { a = Math.abs(a); b = Math.abs(b); return b === 0 ? a : gcd(b, a % b); }
function simplify(n, d) { const g = gcd(n, d); return [n / g, d / g]; }
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) { const j = randInt(0, i); [a[i], a[j]] = [a[j], a[i]]; }
  return a;
}
function fmtSign(n) { return n < 0 ? `(${n})` : `${n}`; }
function fmtTerm(coeff, first) {
  if (first) return `${coeff}`;
  return coeff >= 0 ? `+ ${coeff}` : `− ${Math.abs(coeff)}`;
}

// ─── GENERATORS: 1. Rational Numbers ───
function genMultTables() {
  const a = randInt(2, 12), b = randInt(2, 12);
  return { question: `What is ${a} × ${b}?`, answer: `${a * b}`,
    solution: `${a} × ${b} = ${a * b}`,
    hint: `Think of ${a} groups of ${b}.`,
    accept: i => parseInt(i) === a * b };
}
function genFactorsOf() {
  const n = randInt(12, 48);
  const factors = [];
  for (let i = 1; i <= n; i++) if (n % i === 0) factors.push(i);
  return { question: `List all factors of ${n} (separate with commas).`, answer: factors.join(', '),
    solution: `Factors of ${n}: ${factors.join(', ')}\nCheck each number 1 to ${n} — if ${n} ÷ that number has no remainder, it's a factor.`,
    hint: `Start from 1 and work up. Remember factors come in pairs.`,
    accept: i => {
      const got = i.split(/[,\s]+/).map(Number).filter(x => !isNaN(x)).sort((a,b)=>a-b);
      return JSON.stringify(got) === JSON.stringify(factors);
    }};
}
function genEquivFraction() {
  const n = randInt(1, 8), d = randInt(n + 1, 12), m = randInt(2, 5);
  return { question: `Find an equivalent fraction to ${n}/${d} with denominator ${d * m}.`,
    answer: `${n * m}/${d * m}`,
    solution: `${n}/${d} — multiply top and bottom by ${m}\n${n} × ${m} = ${n * m}\n${d} × ${m} = ${d * m}\nAnswer: ${n * m}/${d * m}`,
    hint: `What did you multiply ${d} by to get ${d * m}? Do the same to the numerator.`,
    accept: i => i.replace(/\s/g, '') === `${n * m}/${d * m}` };
}
function genSimplifyFraction() {
  const g = randInt(2, 6), n = randInt(1, 8), d = randInt(n + 1, 10);
  const num = n * g, den = d * g;
  return { question: `Simplify ${num}/${den} to lowest terms.`, answer: `${n}/${d}`,
    solution: `GCF of ${num} and ${den} is ${g}\n${num} ÷ ${g} = ${n}\n${den} ÷ ${g} = ${d}\nAnswer: ${n}/${d}`,
    hint: `Find the greatest common factor of ${num} and ${den}, then divide both by it.`,
    accept: i => { const p = i.replace(/\s/g,'').split('/'); return p.length===2 && parseInt(p[0])===n && parseInt(p[1])===d; }};
}
function genDecFracPercent() {
  const pairs = [[0.25,'1/4','25%'],[0.5,'1/2','50%'],[0.75,'3/4','75%'],[0.2,'1/5','20%'],[0.4,'2/5','40%'],[0.1,'1/10','10%'],[0.125,'1/8','12.5%']];
  const [dec, frac, pct] = pairs[randInt(0, pairs.length - 1)];
  const mode = randInt(0, 2);
  if (mode === 0) return { question: `Convert ${dec} to a fraction in lowest terms.`, answer: frac,
    solution: `${dec} as a fraction:\n${dec} = ${frac}`, hint: `Think about place value — what is ${dec} out of 1?`,
    accept: i => i.replace(/\s/g,'') === frac };
  if (mode === 1) return { question: `Convert ${frac} to a percent.`, answer: pct,
    solution: `${frac} as a percent:\nDivide: ${frac} = ${dec}\n${dec} × 100 = ${pct}`, hint: `First convert to a decimal, then multiply by 100.`,
    accept: i => i.replace(/\s/g,'').replace('%','') === pct.replace('%','') };
  return { question: `Convert ${pct} to a decimal.`, answer: `${dec}`,
    solution: `${pct} as a decimal:\n${pct} ÷ 100 = ${dec}`, hint: `Divide by 100 — move the decimal two places left.`,
    accept: i => parseFloat(i) === dec };
}
function genOrderIntegers() {
  const nums = Array.from({length: 5}, () => randInt(-20, 20));
  const sorted = [...nums].sort((a,b) => a - b);
  return { question: `Order from least to greatest: ${nums.join(', ')}`, answer: sorted.join(', '),
    solution: `Place on a number line:\nFarthest left (most negative) → farthest right (most positive)\n${sorted.join(', ')}`,
    hint: `Negative numbers go left on the number line. More negative = smaller.`,
    accept: i => { const got = i.split(/[,\s]+/).map(Number).filter(x=>!isNaN(x)); return JSON.stringify(got)===JSON.stringify(sorted); }};
}

// ─── GENERATORS: 2. Square Roots ───
function genMultiply2Digit() {
  const a = randInt(11, 19), b = randInt(11, 19);
  return { question: `What is ${a} × ${b}?`, answer: `${a * b}`,
    solution: `${a} × ${b}\n= ${a} × ${Math.floor(b/10)*10} + ${a} × ${b%10}\n= ${a * Math.floor(b/10)*10} + ${a * (b%10)}\n= ${a * b}`,
    hint: `Break ${b} into ${Math.floor(b/10)*10} + ${b%10} and multiply each part.`,
    accept: i => parseInt(i) === a * b };
}
function genSquareArea() {
  const s = randInt(2, 15);
  return { question: `A square has side length ${s} cm. What is its area?`, answer: `${s * s} cm²`,
    solution: `Area of a square = side × side\n= ${s} × ${s}\n= ${s * s} cm²`,
    hint: `Area of a square = side × side.`,
    accept: i => parseInt(i.replace(/[^\d]/g,'')) === s * s };
}
function genFactorPairs() {
  const n = randInt(12, 50);
  const pairs = [];
  for (let i = 1; i * i <= n; i++) if (n % i === 0) pairs.push(`${i} × ${n/i}`);
  return { question: `List all factor pairs of ${n} (e.g. "1 × ${n}, 2 × ...").`, answer: pairs.join(', '),
    solution: `Factor pairs of ${n}:\n${pairs.join('\n')}`,
    hint: `Start from 1 × ${n} and work inward.`,
    accept: i => {
      const got = i.split(/[,;]+/).map(s => s.trim().split(/\s*[×x*]\s*/).map(Number).sort((a,b)=>a-b)).sort((a,b)=>a[0]-b[0]);
      const exp = pairs.map(s => s.split(' × ').map(Number).sort((a,b)=>a-b)).sort((a,b)=>a[0]-b[0]);
      return JSON.stringify(got) === JSON.stringify(exp);
    }};
}
function genEvalExponent() {
  const b = randInt(2, 10), e = randInt(2, 3);
  const val = Math.pow(b, e);
  return { question: `Evaluate: ${b}${e === 2 ? '²' : '³'}`, answer: `${val}`,
    solution: `${b}${e === 2 ? '²' : '³'} = ${Array(e).fill(b).join(' × ')} = ${val}`,
    hint: `${b}${e === 2 ? '²' : '³'} means ${Array(e).fill(b).join(' × ')}.`,
    accept: i => parseInt(i) === val };
}
function genIdentifyHypotenuse() {
  const a = randInt(3, 12), b = randInt(a, 15);
  const c = Math.round(Math.sqrt(a*a + b*b) * 10) / 10;
  return { question: `A right triangle has legs ${a} cm and ${b} cm. Which side is the hypotenuse — the longest side opposite the right angle? What is its length (round to 1 decimal)?`,
    answer: `${c}`,
    solution: `The hypotenuse is the longest side, opposite the right angle.\na² + b² = c²\n${a}² + ${b}² = c²\n${a*a} + ${b*b} = c²\n${a*a+b*b} = c²\nc = √${a*a+b*b} ≈ ${c}`,
    hint: `The hypotenuse is always across from the right angle. Use a² + b² = c².`,
    accept: i => Math.abs(parseFloat(i) - c) < 0.15 };
}

// ─── GENERATORS: 3. Powers & Exponents ───
function genMultDivFluency() {
  const op = randInt(0, 1);
  if (op === 0) { const a = randInt(3, 12), b = randInt(3, 12); return { question: `${a} × ${b} = ?`, answer: `${a*b}`, solution: `${a} × ${b} = ${a*b}`, hint: `Think of ${a} groups of ${b}.`, accept: i => parseInt(i) === a*b }; }
  const b = randInt(2, 12), q = randInt(2, 12), a = b * q;
  return { question: `${a} ÷ ${b} = ?`, answer: `${q}`, solution: `${a} ÷ ${b} = ${q}\nBecause ${b} × ${q} = ${a}`, hint: `What number times ${b} gives ${a}?`, accept: i => parseInt(i) === q };
}
function genRepeatedMult() {
  const b = randInt(2, 9), e = randInt(2, 5);
  const expr = Array(e).fill(b).join(' × ');
  return { question: `Write as a power: ${expr}`, answer: `${b}^${e}`,
    solution: `${expr}\n= ${b} multiplied ${e} times\n= ${b}^${e} (base ${b}, exponent ${e})`,
    hint: `Count how many times ${b} is multiplied. That count is the exponent.`,
    accept: i => { const c = i.replace(/\s/g,''); return c === `${b}^${e}` || c === `${b}${e===2?'²':e===3?'³':''}` || c === `${b}**${e}`; }};
}
function genBEDMAS() {
  const a = randInt(2, 8), b = randInt(1, 5), c = randInt(2, 4), d = randInt(1, 9);
  const expr = `${a} + ${b} × ${c}²`;
  const val = a + b * c * c;
  return { question: `Evaluate: ${expr}`, answer: `${val}`,
    solution: `${expr}\n= ${a} + ${b} × ${c*c}  (exponent first)\n= ${a} + ${b*c*c}  (multiply next)\n= ${val}  (add last)`,
    hint: `BEDMAS: do the exponent first, then multiply, then add.`,
    accept: i => parseInt(i) === val };
}
function genMultDivNeg() {
  const a = randInt(2, 10) * (randInt(0,1) ? 1 : -1), b = randInt(2, 10) * (randInt(0,1) ? 1 : -1);
  const op = randInt(0, 1);
  if (op === 0) return { question: `${fmtSign(a)} × ${fmtSign(b)} = ?`, answer: `${a*b}`, solution: `${fmtSign(a)} × ${fmtSign(b)}\n${a<0!==b<0 ? 'Different signs → negative' : 'Same signs → positive'}\n${Math.abs(a)} × ${Math.abs(b)} = ${Math.abs(a*b)}\nAnswer: ${a*b}`, hint: `Same signs → positive. Different signs → negative.`, accept: i => parseInt(i) === a*b };
  const q = a, prod = a * b;
  return { question: `${fmtSign(prod)} ÷ ${fmtSign(b)} = ?`, answer: `${q}`, solution: `${fmtSign(prod)} ÷ ${fmtSign(b)}\n${prod<0!==b<0 ? 'Different signs → negative' : 'Same signs → positive'}\n${Math.abs(prod)} ÷ ${Math.abs(b)} = ${Math.abs(q)}\nAnswer: ${q}`, hint: `Same signs → positive. Different signs → negative.`, accept: i => parseInt(i) === q };
}
function genNegBasePower() {
  const b = randInt(2, 5), e = randInt(2, 3);
  const withBrackets = Math.pow(-b, e);
  const without = -Math.pow(b, e);
  const mode = randInt(0, 1);
  if (mode === 0) return { question: `Evaluate: (−${b})${e===2?'²':'³'}`, answer: `${withBrackets}`,
    solution: `(−${b})${e===2?'²':'³'}\n= ${Array(e).fill(`(−${b})`).join(' × ')}\n= ${withBrackets}\n${e%2===0 ? 'Even exponent → positive result' : 'Odd exponent → negative result'}`,
    hint: `The negative is inside the brackets, so it gets raised to the power too.`,
    accept: i => parseInt(i) === withBrackets };
  return { question: `Evaluate: −${b}${e===2?'²':'³'}`, answer: `${without}`,
    solution: `−${b}${e===2?'²':'³'}\n= −(${b}${e===2?'²':'³'})\n= −(${Math.pow(b,e)})\n= ${without}\nThe negative is NOT raised to the power — only ${b} is.`,
    hint: `Without brackets, only ${b} is squared. The negative stays in front.`,
    accept: i => parseInt(i) === without };
}

// ─── GENERATORS: 4. Linear Relations ───
function genPlotPoint() {
  const x = randInt(-8, 8), y = randInt(-8, 8);
  return { question: `Where would you plot the point (${x}, ${y})? State the quadrant (I, II, III, IV) or axis.`,
    answer: x===0||y===0 ? 'on an axis' : (x>0&&y>0?'I':x<0&&y>0?'II':x<0&&y<0?'III':'IV'),
    solution: `(${x}, ${y})\nx = ${x} → move ${x>0?'right':'left'} ${Math.abs(x)}\ny = ${y} → move ${y>0?'up':'down'} ${Math.abs(y)}\n${x===0||y===0?'The point is on an axis.':'Quadrant '+(x>0&&y>0?'I':x<0&&y>0?'II':x<0&&y<0?'III':'IV')}`,
    hint: `x tells you left/right, y tells you up/down. Quadrant I is top-right, going counter-clockwise.`,
    accept: i => { const c = i.trim().toUpperCase().replace(/[^IVX1234AXIS]/gi,''); const ans = x===0||y===0?'AXIS':(x>0&&y>0?'I':x<0&&y>0?'II':x<0&&y<0?'III':'IV'); return c.includes(ans); }};
}
function genPatternRule() {
  const start = randInt(-5, 10), diff = randInt(-5, 8);
  if (diff === 0) return genPatternRule();
  const seq = Array.from({length: 5}, (_, i) => start + diff * i);
  return { question: `Find the common difference: ${seq.join(', ')}, …`, answer: `${diff}`,
    solution: `${seq[1]} − ${seq[0]} = ${diff}\n${seq[2]} − ${seq[1]} = ${diff}\nThe common difference is ${diff}.`,
    hint: `Subtract any term from the next term.`,
    accept: i => parseInt(i) === diff };
}
function genCompleteTable() {
  const m = randInt(1, 5) * (randInt(0,1)?1:-1), b = randInt(-10, 10);
  const x = randInt(-5, 5);
  const y = m * x + b;
  const rule = `y = ${m===1?'':m===-1?'−':m}x ${b>=0?'+ '+b:'− '+Math.abs(b)}`;
  return { question: `If ${rule}, find y when x = ${x}.`, answer: `${y}`,
    solution: `${rule}\ny = ${m===1?'':m===-1?'−':m}(${x}) ${b>=0?'+ '+b:'− '+Math.abs(b)}\ny = ${m*x} ${b>=0?'+ '+b:'− '+Math.abs(b)}\ny = ${y}`,
    hint: `Substitute ${x} for x and calculate.`,
    accept: i => parseInt(i) === y };
}
function genAddSubIntegers() {
  const a = randInt(-20, 20), b = randInt(-20, 20);
  const op = randInt(0, 1);
  if (op === 0) return { question: `${fmtSign(a)} + ${fmtSign(b)} = ?`, answer: `${a+b}`, solution: `${fmtSign(a)} + ${fmtSign(b)} = ${a+b}`, hint: `Same signs: add and keep the sign. Different signs: subtract and keep the sign of the larger absolute value.`, accept: i => parseInt(i) === a+b };
  return { question: `${fmtSign(a)} − ${fmtSign(b)} = ?`, answer: `${a-b}`, solution: `${fmtSign(a)} − ${fmtSign(b)}\n= ${fmtSign(a)} + ${fmtSign(-b)}\n= ${a-b}`, hint: `Subtracting is the same as adding the opposite.`, accept: i => parseInt(i) === a-b };
}
function genIndepDep() {
  const scenarios = [
    { text: 'The more hours you study, the higher your test score.', ind: 'hours', dep: 'test score' },
    { text: 'As the temperature drops, hot chocolate sales increase.', ind: 'temperature', dep: 'sales' },
    { text: 'The faster a car drives, the more gas it uses per km.', ind: 'speed', dep: 'gas usage' },
    { text: 'As a plant gets more sunlight, it grows taller.', ind: 'sunlight', dep: 'height' },
    { text: 'The more people at a party, the more pizza is needed.', ind: 'people', dep: 'pizza' },
  ];
  const s = scenarios[randInt(0, scenarios.length - 1)];
  return { question: `"${s.text}"\nWhat is the independent variable?`, answer: s.ind,
    solution: `Independent (you control): ${s.ind}\nDependent (it responds): ${s.dep}\nThe independent variable is what changes first or what you choose.`,
    hint: `The independent variable is the one you control or that changes first.`,
    accept: i => i.toLowerCase().includes(s.ind.toLowerCase()) };
}

// ─── GENERATORS: 5. Linear Equations ───
function genIntegerOps() {
  const a = randInt(-15, 15), b = randInt(-15, 15);
  const ops = ['+', '−', '×', '÷'];
  const op = randInt(0, 3);
  if (op === 3) { const q = randInt(-10,10); if (q===0||b===0) return genIntegerOps(); const prod = q*b; return { question: `${fmtSign(prod)} ÷ ${fmtSign(b)} = ?`, answer:`${q}`, solution:`${fmtSign(prod)} ÷ ${fmtSign(b)} = ${q}`, hint:'Same signs → positive. Different signs → negative.', accept:i=>parseInt(i)===q }; }
  const res = op===0?a+b:op===1?a-b:a*b;
  const opSym = op===0?'+':op===1?'−':'×';
  return { question: `${fmtSign(a)} ${opSym} ${fmtSign(b)} = ?`, answer: `${res}`,
    solution: `${fmtSign(a)} ${opSym} ${fmtSign(b)} = ${res}`, hint: op < 2 ? 'Same signs: add and keep sign. Different signs: subtract.' : 'Same signs → positive. Different signs → negative.',
    accept: i => parseInt(i) === res };
}
function genInverseOp() {
  const ops = [['addition','subtraction'],['subtraction','addition'],['multiplication','division'],['division','multiplication']];
  const [op, inv] = ops[randInt(0, ops.length - 1)];
  return { question: `What is the inverse operation of ${op}?`, answer: inv,
    solution: `${op} ↔ ${inv}\nInverse operations "undo" each other.`,
    hint: `Inverse means "undo". What undoes ${op}?`,
    accept: i => i.toLowerCase().trim() === inv };
}
function genOneStepEq() {
  const x = randInt(-12, 12);
  const mode = randInt(0, 3);
  if (mode === 0) { const b = randInt(1,15); return { question: `Solve: x + ${b} = ${x+b}`, answer:`${x}`, solution:`x + ${b} = ${x+b}\nx = ${x+b} − ${b}\nx = ${x}`, hint:`Subtract ${b} from both sides.`, accept:i=>parseInt(i)===x }; }
  if (mode === 1) { const b = randInt(1,15); return { question: `Solve: x − ${b} = ${x-b}`, answer:`${x}`, solution:`x − ${b} = ${x-b}\nx = ${x-b} + ${b}\nx = ${x}`, hint:`Add ${b} to both sides.`, accept:i=>parseInt(i)===x }; }
  if (mode === 2) { const a = randInt(2,9); return { question: `Solve: ${a}x = ${a*x}`, answer:`${x}`, solution:`${a}x = ${a*x}\nx = ${a*x} ÷ ${a}\nx = ${x}`, hint:`Divide both sides by ${a}.`, accept:i=>parseInt(i)===x }; }
  const a = randInt(2,7); if(x===0) return genOneStepEq(); const prod = a*x;
