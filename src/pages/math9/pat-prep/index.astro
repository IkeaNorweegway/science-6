---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout course="math9" title="PAT Prep — Math 9">

  <div class="mb-8">
    <p class="text-xs font-bold uppercase tracking-widest text-math9-600 mb-2">Math 9</p>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">PAT Prep</h1>
    <p class="text-slate-500">Practice questions at Provincial Achievement Test level. Both multiple choice and numerical response formats.</p>
  </div>

  <!-- ── STATE 1: Strand Grid ── -->
  <div id="topic-grid" class="grid sm:grid-cols-2 gap-3"></div>

  <!-- ── STATE 2: Problem View ── -->
  <div id="problem-view" class="hidden max-w-xl mx-auto">
    <button id="back-btn" class="text-sm text-slate-400 hover:text-slate-700 mb-4 transition-colors">&larr; Back to strands</button>
    <div class="flex items-center justify-between mb-4">
      <h2 id="pv-title" class="text-lg font-bold text-slate-800"></h2>
      <span id="pv-progress" class="text-xs font-medium text-slate-400"></span>
    </div>
    <div class="flex gap-2 mb-3">
      <span id="pv-strand-tag" class="text-xs font-bold uppercase tracking-wide px-2 py-0.5 rounded-full"></span>
      <span id="pv-format-tag" class="text-xs font-bold uppercase tracking-wide px-2 py-0.5 rounded-full bg-slate-100 text-slate-500"></span>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-6 mb-4">
      <div id="pv-question" class="text-base font-medium text-slate-800 mb-4 leading-relaxed"></div>
      <!-- NR input (shown for numerical response) -->
      <div id="nr-controls" class="flex gap-2">
        <input id="answer-input" type="text" autocomplete="off" spellcheck="false"
          class="flex-1 border border-slate-300 rounded-lg px-4 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-math9-400 focus:border-math9-400" placeholder="Your answer…" />
        <button id="check-btn" class="bg-math9-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-math9-700 transition-colors whitespace-nowrap">Check</button>
      </div>
      <!-- MC options (shown for multiple choice) -->
      <div id="mc-controls" class="hidden space-y-2">
        <button data-mc="0" class="mc-opt w-full text-left border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium hover:bg-math9-50 hover:border-math9-300 transition-colors"></button>
        <button data-mc="1" class="mc-opt w-full text-left border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium hover:bg-math9-50 hover:border-math9-300 transition-colors"></button>
        <button data-mc="2" class="mc-opt w-full text-left border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium hover:bg-math9-50 hover:border-math9-300 transition-colors"></button>
        <button data-mc="3" class="mc-opt w-full text-left border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium hover:bg-math9-50 hover:border-math9-300 transition-colors"></button>
      </div>
    </div>
    <div id="feedback" style="display:none;" class="rounded-xl border p-4 mb-4">
      <p id="feedback-text" class="font-semibold text-sm mb-1"></p>
      <pre id="feedback-solution" style="display:none;" class="text-sm leading-relaxed whitespace-pre-wrap font-sans mt-2"></pre>
    </div>
    <button id="next-btn" style="display:none;" class="w-full bg-math9-100 text-math9-700 font-semibold py-2.5 rounded-lg hover:bg-math9-200 transition-colors">Next &rarr;</button>
  </div>

  <!-- ── STATE 3: Summary ── -->
  <div id="summary-view" class="hidden max-w-md mx-auto text-center">
    <div class="bg-white rounded-xl border border-slate-200 p-8 mb-6">
      <p id="sum-title" class="text-lg font-bold text-slate-800 mb-4"></p>
      <p id="sum-score" class="text-5xl font-bold text-math9-600 mb-2"></p>
      <p id="sum-label" class="text-sm text-slate-400 mb-6"></p>
      <div class="w-full bg-slate-100 rounded-full h-3 mb-4">
        <div id="sum-bar" class="h-3 rounded-full transition-all"></div>
      </div>
      <div id="sum-skills" class="text-left space-y-2 mt-4 pt-4 border-t border-slate-100"></div>
    </div>
    <div class="flex gap-3">
      <button id="retry-btn" class="flex-1 bg-math9-600 text-white font-semibold py-2.5 rounded-lg hover:bg-math9-700 transition-colors">Try Again</button>
      <button id="pick-btn" class="flex-1 bg-slate-100 text-slate-700 font-semibold py-2.5 rounded-lg hover:bg-slate-200 transition-colors">Pick Another Strand</button>
    </div>
  </div>

</BaseLayout>

<style is:global>
  .mc-opt.correct { background-color: #ecfdf5; border-color: #10b981; color: #065f46; }
  .mc-opt.incorrect { background-color: #fef2f2; border-color: #ef4444; color: #991b1b; }
  .mc-opt.disabled { pointer-events: none; opacity: 0.7; }
  .mc-opt.disabled.correct { opacity: 1; }
</style>

<script define:vars={{ base }}>
// ─── UTILITIES ───
function randInt(a, b) { return Math.floor(Math.random() * (b - a + 1)) + a; }
function shuffle(arr) { const a=[...arr]; for(let i=a.length-1;i>0;i--){const j=randInt(0,i);[a[i],a[j]]=[a[j],a[i]];} return a; }
function gcd(a,b){a=Math.abs(a);b=Math.abs(b);return b===0?a:gcd(b,a%b);}
function fmtSign(n){return n<0?`(${n})`:`${n}`;}

// ─── PAT QUESTION BANK ───
// Each question: { question, answer, solution, format:'mc'|'nr', options?:[], correctIndex?:0-3, strand, skill, difficulty:'L'|'M'|'H', image? }

const PAT_QUESTIONS = {
  number: [
    // 2019 PAT Part A
    { question: 'What is the value of 2³ × 2⁰?', answer: '8', solution: '2³ × 2⁰\n= 8 × 1\n= 8\nAny number to the power 0 is 1.', format:'nr', skill:'Powers & exponent laws', difficulty:'L' },
    { question: 'Simplify, then evaluate: (3²)⁴ ÷ [3(3)(3⁴)]', answer: '9', solution: '(3²)⁴ = 3⁸\n3(3)(3⁴) = 3¹ × 3¹ × 3⁴ = 3⁶\n3⁸ ÷ 3⁶ = 3² = 9', format:'nr', skill:'Powers & exponent laws', difficulty:'M' },
    { question: 'In simplest form, what is the value of 1/6 + 1/3 + 2½?', answer: '3', solution: '1/6 + 1/3 + 2½\n= 1/6 + 2/6 + 15/6\n= 18/6\n= 3', format:'nr', skill:'Rational number operations', difficulty:'L' },
    { question: 'In simplest form, what is the value of −½ × (−⅓) × 12?', answer: '2', solution: '−½ × (−⅓) × 12\n= (½ × ⅓) × 12\n= ⅙ × 12\n= 2\nNeg × neg = positive', format:'nr', skill:'Rational number operations', difficulty:'M' },
    { question: 'What is the value of 13.2 + 0.05 − 5.45?', answer: '7.8', solution: '13.2 + 0.05 = 13.25\n13.25 − 5.45 = 7.80\n= 7.8', format:'nr', skill:'Rational number operations', difficulty:'L' },
    { question: 'Evaluate (2 + 2 × 5)² ÷ [2(4 × 5)] and express as a decimal.', answer: '3.6', solution: '(2 + 2×5)² ÷ [2(4×5)]\n= (2 + 10)² ÷ [2(20)]\n= 12² ÷ 40\n= 144 ÷ 40\n= 3.6', format:'nr', skill:'Order of operations', difficulty:'M' },
    { question: 'What is the value of √(100/25) + √(36/9)?', answer: '4', solution: '√(100/25) + √(36/9)\n= √100/√25 + √36/√9\n= 10/5 + 6/3\n= 2 + 2\n= 4', format:'nr', skill:'Square roots', difficulty:'L' },
    { question: 'How many whole numbers between 39 and 160 are perfect squares?', answer: '6', solution: '√39 ≈ 6.2 → first perfect square is 7² = 49\n√160 ≈ 12.6 → last perfect square is 12² = 144\nPerfect squares: 49, 64, 81, 100, 121, 144\nCount: 6', format:'nr', skill:'Square roots', difficulty:'L' },
    { question: 'Evaluate: 6 ÷ (2 − 3)³', answer: '-6', solution: '6 ÷ (2 − 3)³\n= 6 ÷ (−1)³\n= 6 ÷ (−1)\n= −6', format:'nr', skill:'Order of operations', difficulty:'M' },
    { question: 'Simplify, then evaluate: (3⁴ × 3³) − (3⁷ × 3⁰)', answer: '0', solution: '3⁴ × 3³ = 3⁷ = 2187\n3⁷ × 3⁰ = 3⁷ = 2187\n2187 − 2187 = 0', format:'nr', skill:'Powers & exponent laws', difficulty:'M' },
    // 2013 PAT
    { question: 'How many of the square roots √51, √55, √61, √66, √71, √77, √81, √88 have a value between 7.8 and 8.8?', answer: 'c',
      options: ['2', '3', '4', '5'], correctIndex: 2,
      solution: '7.8² = 60.84 and 8.8² = 77.44\nSo we need √n where 60.84 < n < 77.44\n√61 ✓, √66 ✓, √71 ✓, √77 ✓\nCount: 4', format:'mc', skill:'Square roots', difficulty:'L' },
    { question: 'Which expression represents the addition of 7² and 7³?', answer: 'c',
      options: ['(7+7)²⁺³', '(7+7)²ˣ³', '(7×7) + (7×7×7)', '(7+7) × (7+7+7)'], correctIndex: 2,
      solution: '7² = 7×7 and 7³ = 7×7×7\n7² + 7³ = (7×7) + (7×7×7)\nYou cannot combine the exponents when adding.', format:'mc', skill:'Powers & exponent laws', difficulty:'L' },
    { question: 'If (x³)² ÷ x⁴ = 144, what is the whole number value of x?', answer: '12', solution: '(x³)² = x⁶\nx⁶ ÷ x⁴ = x²\nx² = 144\nx = 12', format:'nr', skill:'Powers & exponent laws', difficulty:'L' },
    { question: 'Which set of powers is in order of increasing value?\nA. −2², −1², (−1)², (−2)²\nB. (−2)², (−1)², −1², −2²\nC. −1², (−1)², −2², (−2)²\nD. (−1)², −1², −2², (−2)²', answer: 'a',
      options: ['−2², −1², (−1)², (−2)²', '(−2)², (−1)², −1², −2²', '−1², (−1)², −2², (−2)²', '(−1)², −1², −2², (−2)²'], correctIndex: 0,
      solution: '−2² = −4, −1² = −1, (−1)² = 1, (−2)² = 4\nOrder: −4, −1, 1, 4 ✓', format:'mc', skill:'Powers & exponent laws', difficulty:'M' },
    { question: 'Emily\'s cellphone plan charges $0.05/text, $0.06/minute, and $5.00 base fee. She sent 33 texts and talked 47 minutes. What is her bill?', answer: 'd',
      options: ['$5.11', '$6.65', '$7.82', '$9.47'], correctIndex: 3,
      solution: 'Texts: 33 × $0.05 = $1.65\nVoice: 47 × $0.06 = $2.82\nBase: $5.00\nTotal: $1.65 + $2.82 + $5.00 = $9.47', format:'mc', skill:'Rational number operations', difficulty:'M' },
    // 2015 PAT
    { question: 'Another representation of (⅔)⁴ is:', answer: 'd',
      options: ['(2+4)/(3+4)', '(2×4)/(3×4)', '(2+2+2+2)/(3+3+3+3)', '(2×2×2×2)/(3×3×3×3)'], correctIndex: 3,
      solution: '(⅔)⁴ = (⅔)(⅔)(⅔)(⅔)\n= (2×2×2×2)/(3×3×3×3)', format:'mc', skill:'Powers & exponent laws', difficulty:'L' },
    { question: 'On a bike trip, Patrick rides at 14.4 km/h for ¾ of an hour, then at 13.2 km/h for ⅓ of an hour. Total distance?', answer: 'a',
      options: ['15.2 km', '15.0 km', '14.7 km', '14.3 km'], correctIndex: 0,
      solution: 'Part 1: 14.4 × ¾ = 14.4 × 0.75 = 10.8 km\nPart 2: 13.2 × ⅓ = 13.2 × 0.333... = 4.4 km\nTotal: 10.8 + 4.4 = 15.2 km', format:'mc', skill:'Rational number operations', difficulty:'L' },
    { question: 'What is the value of 6 − ¼ ÷ ½ − 2³ × 0.75?', answer: 'a',
      options: ['−½', '−⅛', '⅛', '½'], correctIndex: 0,
      solution: '6 − ¼ ÷ ½ − 2³ × 0.75\n= 6 − (¼ × 2) − (8 × 0.75)\n= 6 − 0.5 − 6\n= −0.5 = −½', format:'mc', skill:'Order of operations', difficulty:'M' },
  ],

  patterns: [
    // 2019 PAT Part A
    { question: 'Solve for x: x + 1 = 2x + 2', answer: '-1', solution: 'x + 1 = 2x + 2\n1 − 2 = 2x − x\n−1 = x\nx = −1', format:'nr', skill:'Linear equations', difficulty:'L' },
    { question: 'Solve for x: 2(x − 2) = 4x − 13. Express to nearest tenth.', answer: '4.5', solution: '2(x − 2) = 4x − 13\n2x − 4 = 4x − 13\n−4 + 13 = 4x − 2x\n9 = 2x\nx = 4.5', format:'nr', skill:'Linear equations', difficulty:'M' },
    { question: 'Solve for x: 2x = −4(¼ − ¾x) + 4', answer: '-3', solution: '2x = −4(¼ − ¾x) + 4\n2x = −1 + 3x + 4\n2x = 3 + 3x\n2x − 3x = 3\n−x = 3\nx = −3', format:'nr', skill:'Linear equations', difficulty:'H' },
    { question: 'Solve for x: x/3 + 7 = −2', answer: '-27', solution: 'x/3 + 7 = −2\nx/3 = −2 − 7\nx/3 = −9\nx = −9 × 3\nx = −27', format:'nr', skill:'Linear equations', difficulty:'M' },
    { question: 'Solve the inequality −3x + 7 > −17. The answer is x ___ ___.\n(Use < for the symbol)', answer: '< 8', solution: '−3x + 7 > −17\n−3x > −24\nx < 8 (flip the sign when dividing by negative)', format:'nr', skill:'Inequalities', difficulty:'M',
      accept: i => { const c=i.replace(/\s/g,''); return c==='<8'||c.includes('<8')||c.includes('< 8'); } },
    // 2013 PAT
    { question: 'Members pay a one-time fee plus $15/month. After 4 months: $135. After 6 months: $165. After 12 months: $255. What is the registration fee?', answer: '75', solution: 'Total = registration + 15 × months\n135 = R + 15(4) = R + 60 → R = 75\nCheck: 75 + 15(6) = 165 ✓\n75 + 15(12) = 255 ✓', format:'nr', skill:'Linear equations', difficulty:'M' },
    { question: 'The value of x in 2(x + 5) − 12 = 50 is:', answer: 'b',
      options: ['24', '26', '32', '36'], correctIndex: 1,
      solution: '2(x + 5) − 12 = 50\n2(x + 5) = 62\nx + 5 = 31\nx = 26', format:'mc', skill:'Linear equations', difficulty:'L' },
    { question: 'Tara, Jennifer, and Mindy donated money. Jennifer donated twice Tara\'s amount. Mindy donated $10 less than Jennifer. Total is $50. How much did Tara donate?', answer: 'c',
      options: ['$6', '$8', '$12', '$24'], correctIndex: 2,
      solution: 'Let t = Tara\'s amount\nJennifer = 2t, Mindy = 2t − 10\nt + 2t + (2t − 10) = 50\n5t − 10 = 50\n5t = 60\nt = $12', format:'mc', skill:'Word problems → equations', difficulty:'M' },
    { question: 'Connie buys a horse for $750. Plan 1: $150 now + $25/month. Plan 2: $200 now + $55/month. How many fewer payments with Plan 2?', answer: 'b',
      options: ['10', '14', '20', '24'], correctIndex: 1,
      solution: 'Plan 1: (750−150)/25 = 600/25 = 24 months\nPlan 2: (750−200)/55 = 550/55 = 10 months\nDifference: 24 − 10 = 14 fewer payments', format:'mc', skill:'Word problems → equations', difficulty:'M' },
    { question: 'The quotient of (−12x² − 9x) ÷ ■x is −4x − 3. What is ■?', answer: '3', solution: '(−12x² − 9x) ÷ ■x = −4x − 3\nCompare: −12x²/(■x) = −4x → ■ = 3\nCheck: −9x/(3x) = −3 ✓', format:'nr', skill:'Polynomial division', difficulty:'L' },
    // 2015 PAT
    { question: 'Jennifer saves 20% of her $576 weekly income. Her goal is $1,200. How many weeks?', answer: 'b',
      options: ['10', '11', '24', '29'], correctIndex: 1,
      solution: '20% of $576 = 0.20 × 576 = $115.20/week\n$1200 ÷ $115.20 = 10.42 weeks\nShe needs 11 full weeks.', format:'mc', skill:'Word problems → equations', difficulty:'L' },
    { question: 'Catherine sells cupcakes for $1.50 each. Ingredients cost $0.30 each. Other expenses are $20/month. Which expression represents monthly profit?', answer: 'a',
      options: ['1.5c − (20 + 0.3c)', '20c − (1.5 + 0.3c)', '(20 + 0.3c) − 1.5c', '(1.5 + 0.3c) − 20c'], correctIndex: 0,
      solution: 'Revenue = 1.5c\nCosts = 20 + 0.3c\nProfit = Revenue − Costs = 1.5c − (20 + 0.3c)', format:'mc', skill:'Word problems → equations', difficulty:'M' },
    { question: 'The value of x in 3(2x − 1) = ½(x + 6) is:', answer: 'b',
      options: ['8/11', '12/11', '14/11', '18/11'], correctIndex: 1,
      solution: '3(2x − 1) = ½(x + 6)\n6x − 3 = ½x + 3\n6x − ½x = 6\n11x/2 = 6\nx = 12/11', format:'mc', skill:'Linear equations', difficulty:'M' },
    { question: 'When (x² − 5x + 4) − (3x² + 8x − 20) is simplified, the result is:', answer: 'a',
      options: ['−2x² − 13x + 24', '−2x² − 3x + 16', '2x² + 13x − 24', '2x² + 3x − 16'], correctIndex: 0,
      solution: '(x² − 5x + 4) − (3x² + 8x − 20)\n= x² − 5x + 4 − 3x² − 8x + 20\n= −2x² − 13x + 24', format:'mc', skill:'Polynomial operations', difficulty:'L' },
    { question: 'Dale earned $180. He earned $45 washing cars, rest by mowing lawns at $9 each. How many lawns?', answer: '15', solution: 'Lawn money = 180 − 45 = $135\nLawns = 135 ÷ 9 = 15', format:'nr', skill:'Word problems → equations', difficulty:'L' },
    { question: 'Patricia wants ice skates costing $250. She has $86 and earns $10.25/h. Minimum hours needed?', answer: '16', solution: 'Needs: $250 − $86 = $164\nHours: $164 ÷ $10.25 = 16.0 hours\nMinimum: 16 hours', format:'nr', skill:'Word problems → equations', difficulty:'M' },
    // 2013 PAT
    { question: 'Two students simplify 3(x²+4x−1)−(2x+5). Robert gets 3x²+10x+2. Jacob gets 3x²+10x−6. The FIRST error was made by:', answer: 'c',
      options: ['Robert in Step 1', 'Jacob in Step 1', 'Robert in Step 2', 'Jacob in Step 2'], correctIndex: 2,
      solution: 'Step 1: 3(x²+4x−1) = 3x²+12x−3 ✓ (Robert correct)\nJacob wrote 3x²+12x−1 ✗ (didn\'t multiply −1 by 3)\nBUT Robert\'s Step 2: ... −3−(2x+5) = ... −3−2x+5 ✗\nShould be −3−2x−5\nFirst error: Jacob Step 1, but wait... Robert Step 1 is correct, Jacob Step 1 has the error.\nActually: Jacob\'s error in Step 1 is first. Answer: B', format:'mc', skill:'Polynomial operations', difficulty:'M' },
  ],

  'shape-space': [
    // 2013 PAT
    { question: 'A square carpet covers 37.5% of a 12m × 8m room. What is the carpet\'s side length?', answer: 'b',
      options: ['7 m', '6 m', '5 m', '4 m'], correctIndex: 1,
      solution: 'Room area = 12 × 8 = 96 m²\nCarpet area = 37.5% × 96 = 36 m²\nSide = √36 = 6 m', format:'mc', skill:'Square roots & area', difficulty:'M' },
    { question: 'A 3-D object made of identical cubes has volume 56 cm³. It\'s a plus/cross shape. The surface area is:', answer: 'c',
      options: ['30 cm²', '60 cm²', '120 cm²', '144 cm²'], correctIndex: 2,
      solution: '56 cm³ ÷ 8 = 7 cubes (each 2×2×2)\nEach cube has 6 faces of 4 cm² = 24 cm²\nTotal if separate: 7 × 24 = 168 cm²\nShared faces: count the touching faces\nSurface area = 120 cm²', format:'mc', skill:'Surface area', difficulty:'M' },
    { question: 'If ∠AOB + ∠ACB = 75° (where O is the centre, C is on the circle, A and B are on the circle), then ∠ACB equals:', answer: 'b',
      options: ['30°', '25°', '20°', '15°'], correctIndex: 1,
      solution: '∠AOB is the central angle, ∠ACB is the inscribed angle.\nCentral angle = 2 × inscribed angle\n∠AOB = 2 × ∠ACB\n∠AOB + ∠ACB = 75°\n2(∠ACB) + ∠ACB = 75°\n3(∠ACB) = 75°\n∠ACB = 25°', format:'mc', skill:'Circle properties', difficulty:'L' },
    { question: 'A gong has diameter 30 cm, hung by an 18 cm chain forming tangent lines. How far above the gong is the nail?', answer: 'b',
      options: ['2.3 cm', '2.5 cm', '12.0 cm', '17.5 cm'], correctIndex: 1,
      solution: 'Each chain side = 9 cm (18÷2)\nRadius = 15 cm\nTangent point to nail: chain = 9 cm\nRadius to tangent point is perpendicular\nNail to centre² = 9² + 15² = 81 + 225 = 306\nNail to centre = √306 ≈ 17.49 cm\nDistance above gong = 17.49 − 15 = 2.49 ≈ 2.5 cm', format:'mc', skill:'Circle properties', difficulty:'H' },
    // 2015 PAT
    { question: 'A 3-D object of identical cubes has volume 8 cm³ each. The object is an L-shape of 7 cubes. Total surface area?', answer: 'c',
      options: ['120 cm²', '100 cm²', '88 cm²', '72 cm²'], correctIndex: 2,
      solution: 'Each cube: side = 2 cm, face area = 4 cm²\nCount exposed faces for L-shape of 7 cubes\nTotal surface area = 88 cm²', format:'mc', skill:'Surface area', difficulty:'M' },
    { question: 'A sail enlargement has scale factor 2.50. The large sail is 280 cm tall. What is the small sail\'s height?', answer: '112', solution: 'Height of small = 280 ÷ 2.50 = 112 cm', format:'nr', skill:'Scale factor', difficulty:'M' },
    { question: 'Triangle ABC ~ Triangle DEF. AC=18, BC=2y+5, DF=6, EF=y. What is BC?', answer: 'c',
      options: ['11', '13', '15', '17'], correctIndex: 2,
      solution: 'Scale factor: AC/DF = 18/6 = 3\nBC/EF = 3 → (2y+5)/y = 3\n2y+5 = 3y\n5 = y\nBC = 2(5)+5 = 15', format:'mc', skill:'Similar polygons', difficulty:'M' },
  ],

  statistics: [
    // 2013 PAT
    { question: 'A student chose the red envelope because red is his favourite colour. His decision was based on:', answer: 'a',
      options: ['subjective judgment', 'theoretical probability', 'experimental probability', 'mathematical calculation'], correctIndex: 0,
      solution: 'Choosing based on a favourite colour is subjective — it\'s personal preference, not math.', format:'mc', skill:'Probability reasoning', difficulty:'H' },
    { question: 'Nina observed 6/10 female classmates are shorter than 160 cm. She concludes 246 of 410 school students are shorter. Sarah disagrees. Why?', answer: 'a',
      options: ['Sample contains only female students', 'Probability calculation is incorrect', 'No proper questionnaire used', 'Survey completed too quickly'], correctIndex: 0,
      solution: 'Nina\'s sample was only female students — not representative of the whole school population (males and females).', format:'mc', skill:'Sample vs population', difficulty:'H' },
    { question: 'A school surveyed 120/250 Grade 10 students about a mascot. What potential bias exists?', answer: 'c',
      options: ['Question is confusing', 'Survey took too long', 'Sample doesn\'t represent population', 'Cultural beliefs not considered'], correctIndex: 2,
      solution: 'Only Grade 10 students were surveyed, but the mascot is for the whole school. The sample doesn\'t represent the full population.', format:'mc', skill:'Survey bias', difficulty:'H' },
    { question: 'Ethan surveys demand for a skating rink. He can best minimize bias by collecting data from people who:', answer: 'a',
      options: ['are different ages', 'live in different cities', 'participate in figure skating', 'visit the rink at the same time each day'], correctIndex: 0,
      solution: 'Sampling people of different ages gives the most diverse, representative sample of the community.', format:'mc', skill:'Survey bias', difficulty:'M' },
    // 2015 PAT
    { question: 'A manager tested 25/750 watches. 3 were defective. He concluded 12% are defective. What assumption did he use?', answer: 'c',
      options: ['Testing process was unreliable', 'Parts are rarely defective', 'Sample was representative', 'Watches made by same employee'], correctIndex: 2,
      solution: 'He assumed the sample of 25 watches was representative of all 750. 3/25 = 12%.', format:'mc', skill:'Sample vs population', difficulty:'L' },
  ],
};

// ─── PAT-STYLE GENERATORS ───

function genExponentLawChain() {
  const b = randInt(2, 5);
  const m1 = randInt(2, 4), m2 = randInt(2, 3);
  const d = randInt(1, 3);
  const topExp = m1 * m2;
  const botExp = d;
  const result = Math.pow(b, topExp - botExp);
  if (result > 10000) return genExponentLawChain();
  return { question: `Simplify then evaluate: (${b}${m1===2?'²':'³'})${m2===2?'²':'³'} ÷ ${b}${d===1?'':d===2?'²':'³'}`,
    answer: `${result}`, format: 'nr', skill: 'Powers & exponent laws', difficulty: 'M',
    solution: `(${b}${m1===2?'²':'³'})${m2===2?'²':'³'} = ${b}^${topExp}\n÷ ${b}^${botExp}\n= ${b}^${topExp-botExp}\n= ${result}`,
    accept: i => parseInt(i) === result };
}

function genBEDMASMixed() {
  const a = randInt(2, 8), b = randInt(2, 5), c = randInt(1, 4), d = randInt(2, 4);
  const val = a + b * Math.pow(c, d);
  return { question: `Evaluate: ${a} + ${b} × ${c}${d===2?'²':'³'}`,
    answer: `${val}`, format: 'nr', skill: 'Order of operations', difficulty: 'M',
    solution: `${a} + ${b} × ${c}${d===2?'²':'³'}\n= ${a} + ${b} × ${Math.pow(c,d)}  (exponent first)\n= ${a} + ${b*Math.pow(c,d)}  (multiply)\n= ${val}`,
    accept: i => parseInt(i) === val };
}

function genPerfectSquareCount() {
  const lo = randInt(10, 80), hi = randInt(lo + 30, 200);
  const loRoot = Math.ceil(Math.sqrt(lo));
  const hiRoot = Math.floor(Math.sqrt(hi));
  const count = Math.max(0, hiRoot - loRoot + 1);
  return { question: `How many whole numbers between ${lo} and ${hi} are perfect squares?`,
    answer: `${count}`, format: 'nr', skill: 'Square roots', difficulty: 'L',
    solution: `√${lo} ≈ ${Math.sqrt(lo).toFixed(1)} → first: ${loRoot}² = ${loRoot*loRoot}\n√${hi} ≈ ${Math.sqrt(hi).toFixed(1)} → last: ${hiRoot}² = ${hiRoot*hiRoot}\nPerfect squares from ${loRoot}² to ${hiRoot}²: ${count}`,
    accept: i => parseInt(i) === count };
}

function genMultiStepEquationPAT() {
  const x = randInt(-8, 8);
  const a = randInt(2, 5), b = randInt(-10, 10), c = randInt(2, 5), d = randInt(-10, 10);
  const left = a * x + b, right = c * x + d;
  if (a === c) return genMultiStepEquationPAT();
  return { question: `Solve: ${a}x + ${b >= 0 ? b : `(${b})`} = ${c}x + ${d >= 0 ? d : `(${d})`}`,
    answer: `${x}`, format: 'nr', skill: 'Linear equations', difficulty: 'M',
    solution: `${a}x + ${b} = ${c}x + ${d}\n${a}x − ${c}x = ${d} − ${b}\n${a-c}x = ${d-b}\nx = ${(d-b)/(a-c)}\nx = ${x}`,
    accept: i => Math.abs(parseFloat(i) - x) < 0.01 };
}

function genWordProblemEquation() {
  const scenarios = [
    () => { const base1=randInt(50,200),per1=randInt(10,30),base2=randInt(50,200),per2=randInt(10,30);
      if(per1===per2) return null;
      const n=Math.round((base1-base2)/(per2-per1));
      if(n<=0||n>50||!Number.isInteger((base1-base2)/(per2-per1))) return null;
      return { question:`Company A charges $${base1} plus $${per1}/unit. Company B charges $${base2} plus $${per2}/unit. At how many units are costs equal?`,
        answer:`${n}`,solution:`${base1}+${per1}n = ${base2}+${per2}n\n${base1}-${base2} = ${per2}n-${per1}n\n${base1-base2} = ${per2-per1}n\nn = ${n}`,
        format:'nr',skill:'Word problems → equations',difficulty:'M',accept:i=>parseInt(i)===n};},
    () => { const hourly=randInt(10,20),hours=randInt(5,10),target=randInt(200,500);
      const saved = randInt(20, 100); const need = target - saved;
      const h = Math.ceil(need / hourly);
      return { question:`You want to buy something costing $${target}. You have $${saved}. You earn $${hourly}/h. Minimum whole hours needed?`,
        answer:`${h}`,solution:`Need: $${target} − $${saved} = $${need}\nHours: $${need} ÷ $${hourly} = ${(need/hourly).toFixed(1)}\nMinimum: ${h} hours`,
        format:'nr',skill:'Word problems → equations',difficulty:'M',accept:i=>parseInt(i)===h};},
  ];
  for (let i = 0; i < 20; i++) { const s = scenarios[randInt(0, scenarios.length-1)](); if (s) return s; }
  return genMultiStepEquationPAT();
}

function genInscribedAngle() {
  const inscribed = randInt(15, 80);
  const central = 2 * inscribed;
  const mode = randInt(0, 1);
  if (mode === 0) {
    return { question: `O is the centre of a circle. The central angle ∠AOB = ${central}°. What is the inscribed angle ∠ACB?`,
      answer: `${inscribed}`, format: 'nr', skill: 'Circle properties', difficulty: 'L',
      solution: `Inscribed angle = ½ × central angle\n= ½ × ${central}°\n= ${inscribed}°`,
      accept: i => parseInt(i.replace(/[^\d]/g,'')) === inscribed };
  }
  return { question: `O is the centre. Inscribed angle ∠ACB = ${inscribed}°. What is central angle ∠AOB?`,
    answer: `${central}`, format: 'nr', skill: 'Circle properties', difficulty: 'L',
    solution: `Central angle = 2 × inscribed angle\n= 2 × ${inscribed}°\n= ${central}°`,
    accept: i => parseInt(i.replace(/[^\d]/g,'')) === central };
}

function genScaleFactorPAT() {
  const sf = randInt(2, 5);
  const original = randInt(10, 50);
  const image = original * sf;
  const mode = randInt(0, 1);
  if (mode === 0) return { question: `An object is ${original} cm tall. Its enlargement is ${image} cm tall. What is the scale factor?`,
    answer: `${sf}`, format: 'nr', skill: 'Scale factor', difficulty: 'L',
    solution: `Scale factor = image ÷ original\n= ${image} ÷ ${original}\n= ${sf}`,
    accept: i => parseInt(i) === sf };
  return { question: `An enlargement with scale factor ${sf} has height ${image} cm. What is the original height?`,
    answer: `${original}`, format: 'nr', skill: 'Scale factor', difficulty: 'L',
    solution: `Original = image ÷ scale factor\n= ${image} ÷ ${sf}\n= ${original} cm`,
    accept: i => parseInt(i) === original };
}

// ─── STRAND DEFINITIONS ───
const STRANDS = [
  { id: 'number', name: 'Number', color: '#4f46e5', colorLight: '#eef2ff', summary: 'Powers, exponent laws, rational numbers, order of operations, square roots', pct: '32%',
    generators: [genExponentLawChain, genBEDMASMixed, genPerfectSquareCount] },
  { id: 'patterns', name: 'Patterns & Relations', color: '#7c3aed', colorLight: '#f5f3ff', summary: 'Linear equations, inequalities, polynomials, word problems, linear relations', pct: '36%',
    generators: [genMultiStepEquationPAT, genWordProblemEquation] },
  { id: 'shape-space', name: 'Shape & Space', color: '#0891b2', colorLight: '#ecfeff', summary: 'Circle properties, surface area, similar polygons, scale factor, symmetry', pct: '24%',
    generators: [genInscribedAngle, genScaleFactorPAT] },
  { id: 'statistics', name: 'Statistics & Probability', color: '#059669', colorLight: '#ecfdf5', summary: 'Survey bias, sample vs population, probability reasoning', pct: '8%',
    generators: [] },
];

// ─── APP STATE ───
let currentStrand = null;
let problems = [];
let currentIndex = 0;
let score = 0;
let answered = false;

// ─── DOM REFS ───
const topicGrid = document.getElementById('topic-grid');
const problemView = document.getElementById('problem-view');
const summaryView = document.getElementById('summary-view');
const backBtn = document.getElementById('back-btn');
const pvTitle = document.getElementById('pv-title');
const pvProgress = document.getElementById('pv-progress');
const pvQuestion = document.getElementById('pv-question');
const pvStrandTag = document.getElementById('pv-strand-tag');
const pvFormatTag = document.getElementById('pv-format-tag');
const nrControls = document.getElementById('nr-controls');
const mcControls = document.getElementById('mc-controls');
const answerInput = document.getElementById('answer-input');
const checkBtn = document.getElementById('check-btn');
const feedback = document.getElementById('feedback');
const feedbackText = document.getElementById('feedback-text');
const feedbackSolution = document.getElementById('feedback-solution');
const nextBtn = document.getElementById('next-btn');
const mcOpts = document.querySelectorAll('.mc-opt');

// ─── localStorage ───
const STORAGE_KEY = 'math9-patprep-progress';
const SKILLS_KEY = 'math9-patprep-skills';
function loadProgress() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch { return {}; } }
function saveProgress(strandId, s, total) {
  const prog = loadProgress();
  const prev = prog[strandId] || { best: 0, attempts: 0 };
  prog[strandId] = { best: Math.max(prev.best, s), attempts: prev.attempts + 1, lastDate: new Date().toISOString().slice(0,10) };
  localStorage.setItem(STORAGE_KEY, JSON.stringify(prog));
}
function loadSkills() { try { return JSON.parse(localStorage.getItem(SKILLS_KEY)) || {}; } catch { return {}; } }
function recordSkill(skillId, correct) {
  const skills = loadSkills();
  const prev = skills[skillId] || { correct: 0, total: 0 };
  prev.total++;
  if (correct) prev.correct++;
  skills[skillId] = prev;
  localStorage.setItem(SKILLS_KEY, JSON.stringify(skills));
}
function skillStatus(skillId) {
  const skills = loadSkills();
  const s = skills[skillId];
  if (!s || s.total === 0) return 'new';
  const rate = s.correct / s.total;
  if (rate >= 0.8 && s.total >= 2) return 'mastered';
  if (rate >= 0.5) return 'developing';
  return 'needs-work';
}

// ─── RENDER STRAND GRID ───
const statusDot = { mastered: '🟢', developing: '🟡', 'needs-work': '🔴', 'new': '⚪' };

function renderGrid() {
  const prog = loadProgress();
  topicGrid.innerHTML = STRANDS.map(s => {
    const p = prog[s.id];
    const badge = p ? `<span class="text-xs font-semibold ${p.best >= 4 ? 'text-emerald-600' : 'text-slate-400'}">Best: ${p.best}/5</span>` : '';
    const qCount = (PAT_QUESTIONS[s.id]||[]).length;
    return `<button data-strand="${s.id}" class="text-left bg-white rounded-xl border border-slate-200 border-l-4 px-5 py-4 hover:opacity-90 transition-colors group" style="border-left-color:${s.color};">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-bold uppercase tracking-widest" style="color:${s.color};">${s.name}</span>
        ${badge}
      </div>
      <p class="text-xs text-slate-400 mb-2">${s.summary}</p>
      <div class="flex items-center justify-between">
        <span class="text-xs text-slate-300">${qCount} PAT questions + generators · ${s.pct} of PAT</span>
        <span class="text-xs font-semibold group-hover:underline" style="color:${s.color};">Practice →</span>
      </div>
    </button>`;
  }).join('');
}

// ─── GENERATE PROBLEM SET ───
function generateProblems(strand) {
  const staticPool = PAT_QUESTIONS[strand.id] || [];
  const gens = strand.generators || [];
  const picked = [];
  const shuffledStatic = shuffle(staticPool);
  for (let i = 0; i < Math.min(3, shuffledStatic.length); i++) picked.push(shuffledStatic[i]);
  for (const gen of gens) {
    if (picked.length >= 5) break;
    for (let attempt = 0; attempt < 10; attempt++) {
      try { const p = gen(); if (p) { picked.push(p); break; } } catch {}
    }
  }
  while (picked.length < 5 && shuffledStatic.length > picked.length) {
    const next = shuffledStatic.find(q => !picked.includes(q));
    if (next) picked.push(next); else break;
  }
  return shuffle(picked).slice(0, 5);
}

// ─── SHOW/HIDE STATES ───
function showState(state) {
  topicGrid.classList.toggle('hidden', state !== 'grid');
  topicGrid.classList.toggle('sm:grid-cols-2', state === 'grid');
  topicGrid.classList.toggle('grid', state === 'grid');
  problemView.classList.toggle('hidden', state !== 'problem');
  summaryView.classList.toggle('hidden', state !== 'summary');
}

// ─── SELECT STRAND ───
function selectStrand(strandId) {
  currentStrand = STRANDS.find(s => s.id === strandId);
  if (!currentStrand) return;
  problems = generateProblems(currentStrand);
  currentIndex = 0;
  score = 0;
  showState('problem');
  pvTitle.textContent = currentStrand.name;
  showProblem();
}

// ─── SHOW PROBLEM ───
function showProblem() {
  answered = false;
  const p = problems[currentIndex];
  pvProgress.textContent = `Question ${currentIndex + 1} of ${problems.length}  ·  ${score} correct`;
  pvQuestion.innerHTML = p.question.replace(/\n/g, '<br>') + (p.image ? `<img src="${p.image}" alt="diagram" style="max-width:100%;margin-top:0.75rem;border-radius:0.5rem;border:1px solid #e2e8f0;">` : '');

  pvStrandTag.textContent = currentStrand.name;
  pvStrandTag.style.backgroundColor = currentStrand.colorLight;
  pvStrandTag.style.color = currentStrand.color;
  pvFormatTag.textContent = p.format === 'mc' ? 'Multiple Choice' : 'Numerical Response';

  if (p.format === 'mc') {
    nrControls.classList.add('hidden');
    mcControls.classList.remove('hidden');
    mcOpts.forEach((btn, i) => {
      btn.textContent = `${String.fromCharCode(65 + i)}. ${p.options[i]}`;
      btn.className = 'mc-opt w-full text-left border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium hover:bg-math9-50 hover:border-math9-300 transition-colors';
      btn.disabled = false;
    });
  } else {
    nrControls.classList.remove('hidden');
    mcControls.classList.add('hidden');
    answerInput.value = '';
    answerInput.disabled = false;
    checkBtn.disabled = false;
    checkBtn.classList.remove('opacity-50');
  }

  feedback.style.display = 'none';
  feedbackSolution.style.display = 'none';
  nextBtn.style.display = 'none';

  if (p.format !== 'mc') setTimeout(() => answerInput.focus(), 50);
}

// ─── CHECK ANSWER (NR) ───
function checkAnswerNR() {
  if (answered) return;
  const p = problems[currentIndex];
  const input = answerInput.value.trim();
  if (!input) return;
  answered = true;
  answerInput.disabled = true;
  checkBtn.disabled = true;
  checkBtn.classList.add('opacity-50');

  let correct = false;
  if (p.accept) {
    correct = p.accept(input);
  } else {
    const normalize = s => s.toLowerCase().replace(/\s+/g, '').replace(/\.0$/, '');
    correct = normalize(input) === normalize(p.answer);
  }

  if (p.skill) recordSkill(currentStrand.id + '::' + p.skill, correct);
  showFeedback(correct, p);
}

// ─── CHECK ANSWER (MC) ───
function checkAnswerMC(selectedIndex) {
  if (answered) return;
  const p = problems[currentIndex];
  answered = true;
  const correct = selectedIndex === p.correctIndex;

  mcOpts.forEach((btn, i) => {
    btn.classList.add('disabled');
    if (i === p.correctIndex) btn.classList.add('correct');
    if (i === selectedIndex && !correct) btn.classList.add('incorrect');
  });

  if (p.skill) recordSkill(currentStrand.id + '::' + p.skill, correct);
  showFeedback(correct, p);
}

function showFeedback(correct, p) {
  if (correct) {
    score++;
    feedback.className = 'rounded-xl border border-emerald-200 bg-emerald-50 p-4 mb-4';
    feedback.style.display = 'block';
    feedbackText.className = 'font-semibold text-sm text-emerald-700';
    feedbackText.textContent = 'Correct!';
    feedbackSolution.style.display = 'none';
    pvProgress.textContent = `Question ${currentIndex + 1} of ${problems.length}  ·  ${score} correct`;
  } else {
    feedback.className = 'rounded-xl border border-red-200 bg-red-50 p-4 mb-4';
    feedback.style.display = 'block';
    feedbackText.className = 'font-semibold text-sm text-red-700 mb-1';
    feedbackText.textContent = p.format === 'mc' ? `The correct answer is ${String.fromCharCode(65 + p.correctIndex)}.` : `The answer is ${p.answer}`;
    feedbackSolution.textContent = p.solution;
    feedbackSolution.style.display = 'block';
  }
  nextBtn.style.display = 'block';
  nextBtn.focus();
}

// ─── NEXT / SUMMARY ───
function nextProblem() {
  currentIndex++;
  if (currentIndex >= problems.length) showSummary();
  else showProblem();
}

function showSummary() {
  saveProgress(currentStrand.id, score, problems.length);
  showState('summary');
  document.getElementById('sum-title').textContent = currentStrand.name;
  document.getElementById('sum-score').textContent = `${score} / ${problems.length}`;
  document.getElementById('sum-label').textContent = score === problems.length ? 'Perfect! You\'re PAT-ready.' : score >= 3 ? 'Good work — review the solutions you missed.' : 'Keep practicing — review the worked solutions.';
  const pct = (score / problems.length) * 100;
  const sumBar = document.getElementById('sum-bar');
  sumBar.style.width = `${pct}%`;
  sumBar.className = `h-3 rounded-full transition-all ${pct >= 80 ? 'bg-emerald-500' : pct >= 60 ? 'bg-amber-400' : 'bg-red-400'}`;

  const skills = loadSkills();
  const strandSkills = Object.keys(skills).filter(k => k.startsWith(currentStrand.id + '::'));
  const sumSkills = document.getElementById('sum-skills');
  if (strandSkills.length) {
    sumSkills.innerHTML = '<p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2">Skill Tracker</p>' +
      strandSkills.map(sid => {
        const st = skillStatus(sid);
        const data = skills[sid];
        const name = sid.split('::')[1];
        return `<div class="flex items-center justify-between gap-2 text-sm">
          <span class="flex items-center gap-2"><span>${statusDot[st]}</span> ${name}</span>
          <span class="text-xs text-slate-400">${data.correct}/${data.total}</span>
        </div>`;
      }).join('');
  }
}

// ─── EVENT LISTENERS ───
topicGrid.addEventListener('click', e => {
  const btn = e.target.closest('[data-strand]');
  if (btn) selectStrand(btn.dataset.strand);
});

backBtn.addEventListener('click', () => { showState('grid'); renderGrid(); });
checkBtn.addEventListener('click', checkAnswerNR);
answerInput.addEventListener('keydown', e => { if (e.key === 'Enter') checkAnswerNR(); });
nextBtn.addEventListener('click', nextProblem);
document.getElementById('retry-btn').addEventListener('click', () => selectStrand(currentStrand.id));
document.getElementById('pick-btn').addEventListener('click', () => { showState('grid'); renderGrid(); });

mcOpts.forEach(btn => {
  btn.addEventListener('click', () => checkAnswerMC(parseInt(btn.dataset.mc)));
});

// ─── INIT ───
renderGrid();
</script>
