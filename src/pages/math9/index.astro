---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const strands = [
  {
    slug: 'number',
    label: 'Number',
    topics: 'Rational Numbers · Square Roots · Powers & Exponents',
    description: 'Operations with rational numbers, estimating square roots, the Pythagorean theorem, and the full exponent law set.',
    bg: 'bg-blue-50', border: 'border-blue-400', text: 'text-blue-800', link: 'text-blue-700', hover: 'hover:bg-blue-100',
    badge: 'bg-blue-100 text-blue-800',
  },
  {
    slug: 'algebra',
    label: 'Algebra',
    topics: 'Linear Relations · Linear Equations & Inequalities · Polynomials',
    description: 'Slope, y = mx + b, solving multi-step equations, graphing inequalities, and multiplying polynomials.',
    bg: 'bg-violet-50', border: 'border-violet-400', text: 'text-violet-800', link: 'text-violet-700', hover: 'hover:bg-violet-100',
    badge: 'bg-violet-100 text-violet-800',
  },
  {
    slug: 'measurement-geometry',
    label: 'Measurement & Geometry',
    topics: 'Circle Geometry · Surface Area & Volume · Similarity & Scale',
    description: 'Chord and tangent properties, composite 3D objects, similar triangles, and scale diagrams.',
    bg: 'bg-green-50', border: 'border-green-400', text: 'text-green-800', link: 'text-green-700', hover: 'hover:bg-green-100',
    badge: 'bg-green-100 text-green-800',
  },
  {
    slug: 'statistics-probability',
    label: 'Statistics & Probability',
    topics: 'Statistics & Scatter Plots · Probability',
    description: 'Correlation, lines of best fit, interpolation vs. extrapolation, independent and dependent events.',
    bg: 'bg-teal-50', border: 'border-teal-400', text: 'text-teal-800', link: 'text-teal-700', hover: 'hover:bg-teal-100',
    badge: 'bg-teal-100 text-teal-800',
  },
];
---

<BaseLayout course="math9" title="Grade 9 Mathematics">

  <div class="mb-10">
    <p class="text-xs font-bold uppercase tracking-widest text-math9-600 mb-2">Alberta Curriculum</p>
    <h1 class="text-4xl font-bold text-slate-900 mb-3">Grade 9 Mathematics</h1>
    <p class="text-slate-500 text-lg max-w-xl">
      Four strands, eleven topics. Notes, concept pages, worksheets, exit tickets, and answer keys.
    </p>
  </div>

  <!-- Quick stats -->
  <div class="grid grid-cols-4 gap-3 mb-10">
    {[
      { n: '4', label: 'Strands' },
      { n: '11', label: 'Topics' },
      { n: '98', label: 'Materials' },
      { n: '52', label: 'Exit tickets' },
    ].map(s => (
      <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
        <p class="text-2xl font-bold text-math9-700">{s.n}</p>
        <p class="text-xs text-slate-400 mt-1 uppercase tracking-wide">{s.label}</p>
      </div>
    ))}
  </div>

  <!-- Strand cards -->
  <div class="space-y-3">
    {strands.map(s => (
      <a
        href={`${base}math9/materials/${s.slug}`}
        class={`group block bg-white rounded-xl border border-slate-200 border-l-4 ${s.border} p-5 transition-colors ${s.hover}`}
      >
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <p class={`text-xs font-bold uppercase tracking-widest ${s.text} mb-1`}>{s.label}</p>
            <p class="text-xs text-slate-400 mb-2">{s.topics}</p>
            <p class="text-sm text-slate-500 leading-relaxed">{s.description}</p>
          </div>
          <span class={`flex-shrink-0 text-sm font-semibold ${s.link} group-hover:underline whitespace-nowrap`}>
            View →
          </span>
        </div>
      </a>
    ))}
  </div>

  <!-- Prereq Practice -->
  <div class="mt-6">
    <a
      href={`${base}math9/practice`}
      class="group block bg-math9-50 rounded-xl border border-math9-200 border-l-4 border-l-math9-500 p-5 transition-colors hover:bg-math9-100"
    >
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="text-xs font-bold uppercase tracking-widest text-math9-600 mb-1">Prereq Practice</p>
          <p class="text-sm text-slate-500 leading-relaxed">Warm up on the foundational skills you need before each topic. Randomized problems with worked solutions.</p>
        </div>
        <span class="flex-shrink-0 text-sm font-semibold text-math9-600 group-hover:underline whitespace-nowrap">
          Practice →
        </span>
      </div>
    </a>
  </div>

  <!-- PAT Prep -->
  <div class="mt-3">
    <a
      href={`${base}math9/pat-prep`}
      class="group block bg-amber-50 rounded-xl border border-amber-200 border-l-4 border-l-amber-500 p-5 transition-colors hover:bg-amber-100"
    >
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="text-xs font-bold uppercase tracking-widest text-amber-700 mb-1">PAT Prep</p>
          <p class="text-sm text-slate-500 leading-relaxed">Practice at Provincial Achievement Test level. Multiple choice and numerical response, organized by PAT strands.</p>
        </div>
        <span class="flex-shrink-0 text-sm font-semibold text-amber-700 group-hover:underline whitespace-nowrap">
          Practice →
        </span>
      </div>
    </a>
  </div>

</BaseLayout>
