---
interface Props {
  title: string;
  slug: string;
  tier: number;
  weeks: string;
  guidingQuestion: string;
  order: number;
}

const { title, slug, tier, weeks, guidingQuestion, order } = Astro.props;

const tierColors: Record<number, string> = {
  1: 'bg-science-700 text-white',
  2: 'bg-science-500 text-white',
  3: 'bg-slate-400 text-white',
};

const unitColors: Record<string, string> = {
  'matter':           'border-l-cyan-600',
  'forces':           'border-l-violet-600',
  'living-systems':   'border-l-emerald-600',
  'climate':          'border-l-amber-500',
  'energy-resources': 'border-l-orange-500',
  'space':            'border-l-indigo-600',
};

const accent = unitColors[slug] ?? 'border-l-slate-400';
const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}units/${slug}`}
  class={`block bg-white rounded-xl border border-slate-200 border-l-4 ${accent} p-5 hover:shadow-md transition-shadow group`}
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Unit {order}</span>
        <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${tierColors[tier]}`}>
          Tier {tier}
        </span>
        <span class="text-xs text-slate-400">{weeks} weeks</span>
      </div>
      <h2 class="text-lg font-bold text-slate-900 group-hover:text-science-700 transition-colors">
        {title}
      </h2>
      <p class="text-sm text-slate-500 mt-1 italic">{guidingQuestion}</p>
    </div>
    <svg class="w-5 h-5 text-slate-300 group-hover:text-science-600 transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
