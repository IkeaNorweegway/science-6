---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const strands = [
  { slug: 'number',                  label: 'Number' },
  { slug: 'algebra',                 label: 'Algebra' },
  { slug: 'measurement-geometry',    label: 'M&G' },
  { slug: 'statistics-probability',  label: 'Stats & Prob' },
];
---

<nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-14">

      <!-- Logo -->
      <a href={`${base}math9`} class="font-bold text-base tracking-tight text-math9-700">
        Math 9
      </a>

      <!-- Strand nav (desktop) -->
      <div class="hidden md:flex items-center gap-1">
        {strands.map(s => (
          <a
            href={`${base}math9/materials/${s.slug}`}
            class={`text-xs px-2.5 py-1.5 rounded-md font-medium transition-colors
              ${currentPath.includes(s.slug)
                ? 'bg-math9-600 text-white'
                : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'
              }`}
          >
            {s.label}
          </a>
        ))}
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-2">
        <a
          href={`${base}math9/materials`}
          class={`text-xs px-3 py-1.5 rounded-md font-medium transition-colors
            ${currentPath.endsWith('/math9/materials') || currentPath.endsWith('/math9/materials/')
              ? 'bg-math9-600 text-white'
              : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'
            }`}
        >
          All Materials
        </a>
        <a
          href={base}
          class="text-xs px-3 py-1.5 rounded-md font-medium border border-slate-300 text-slate-500 hover:bg-slate-100 hover:text-slate-800 transition-colors"
        >
          ← Courses
        </a>
      </div>
    </div>

    <!-- Mobile strand nav -->
    <div class="md:hidden flex gap-1 pb-2 overflow-x-auto">
      {strands.map(s => (
        <a
          href={`${base}math9/materials/${s.slug}`}
          class={`text-xs px-2.5 py-1 rounded-md font-medium whitespace-nowrap transition-colors
            ${currentPath.includes(s.slug)
              ? 'bg-math9-600 text-white'
              : 'text-slate-600 hover:bg-slate-100'
            }`}
        >
          {s.label}
        </a>
      ))}
      <a
        href={`${base}math9/materials`}
        class={`text-xs px-2.5 py-1 rounded-md font-medium whitespace-nowrap transition-colors
          ${currentPath.endsWith('/math9/materials') || currentPath.endsWith('/math9/materials/')
            ? 'bg-math9-600 text-white'
            : 'text-slate-600 hover:bg-slate-100'
          }`}
      >
        All
      </a>
    </div>
  </div>
</nav>
