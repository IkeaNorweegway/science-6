---
interface Props {
  course?: 'science' | 'math9';
  teacherMode?: boolean;
}
const { course, teacherMode = false } = Astro.props;

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const scienceUnits = [
  { slug: 'matter',           label: 'Matter' },
  { slug: 'forces',           label: 'Forces' },
  { slug: 'living-systems',   label: 'Living Systems' },
  { slug: 'climate',          label: 'Climate' },
  { slug: 'energy-resources', label: 'Energy Resources' },
  { slug: 'space',            label: 'Space' },
];

const math9Strands = [
  { slug: 'number',                 label: 'Number' },
  { slug: 'algebra',                label: 'Algebra' },
  { slug: 'measurement-geometry',   label: 'M&G' },
  { slug: 'statistics-probability', label: 'Stats & Prob' },
];

const navBg   = teacherMode ? 'bg-slate-900 border-slate-700' : 'bg-white border-slate-200';
const textBase = teacherMode ? 'text-slate-300' : 'text-slate-600';
const hoverBase = teacherMode ? 'hover:bg-slate-700 hover:text-white' : 'hover:bg-slate-100 hover:text-slate-900';
---

<nav class={`border-b ${navBg} sticky top-0 z-50`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <!-- ── Top bar ── -->
    <div class="flex items-center justify-between h-14">

      <!-- Site name → home -->
      <a
        href={base}
        class={`font-bold text-base tracking-tight ${teacherMode ? 'text-white' : 'text-slate-800'} hover:opacity-80 transition-opacity`}
      >
        Mr. Bremness
      </a>

      <!-- Course tabs (desktop) -->
      <div class="hidden sm:flex items-center gap-1">
        <a
          href={`${base}materials`}
          class={`text-xs px-3 py-1.5 rounded-md font-medium transition-colors
            ${course === 'science'
              ? (teacherMode ? 'bg-teacher-600 text-white' : 'bg-science-600 text-white')
              : `${textBase} ${hoverBase}`
            }`}
        >
          Gr. 6 Science
        </a>
        <a
          href={`${base}math9`}
          class={`text-xs px-3 py-1.5 rounded-md font-medium transition-colors
            ${course === 'math9'
              ? 'bg-math9-600 text-white'
              : `${textBase} ${hoverBase}`
            }`}
        >
          Math 9
        </a>
      </div>

      <!-- Right: Teacher toggle -->
      <a
        href={teacherMode ? (course === 'math9' ? `${base}math9` : `${base}materials`) : (course === 'math9' ? `${base}math9/teacher` : `${base}teacher`)}
        class={`text-xs px-3 py-1.5 rounded-md font-medium border transition-colors
          ${teacherMode
            ? 'border-teacher-500 text-teacher-400 hover:bg-teacher-700 hover:text-white'
            : 'border-slate-300 text-slate-500 hover:bg-slate-100 hover:text-slate-800'
          }`}
      >
        {teacherMode ? '← Student view' : 'Teacher'}
      </a>
    </div>

    <!-- ── Course subnav ── -->
    {course === 'science' && (
      <div class="flex gap-1 pb-2 overflow-x-auto">
        {scienceUnits.map(u => (
          <a
            href={`${base}units/${u.slug}`}
            class={`text-xs px-2.5 py-1 rounded-md font-medium whitespace-nowrap transition-colors
              ${currentPath.includes(u.slug)
                ? (teacherMode ? 'bg-teacher-600 text-white' : 'bg-science-600 text-white')
                : (teacherMode ? 'text-slate-400 hover:bg-slate-700 hover:text-white' : 'text-slate-600 hover:bg-slate-100')
              }`}
          >
            {u.label}
          </a>
        ))}
        <a
          href={`${base}materials`}
          class={`text-xs px-2.5 py-1 rounded-md font-medium whitespace-nowrap transition-colors
            ${currentPath.includes('/materials') && !currentPath.includes('/materials/fr') && !currentPath.includes('/units/')
              ? (teacherMode ? 'bg-teacher-600 text-white' : 'bg-science-600 text-white')
              : (teacherMode ? 'text-slate-400 hover:bg-slate-700 hover:text-white' : 'text-slate-600 hover:bg-slate-100')
            }`}
        >
          All Materials
        </a>
        <a
          href={`${base}materials/fr`}
          class={`text-xs px-2.5 py-1 rounded-md font-medium whitespace-nowrap transition-colors
            ${currentPath.includes('/materials/fr')
              ? 'bg-blue-600 text-white'
              : (teacherMode ? 'text-slate-400 hover:bg-slate-700 hover:text-white' : 'text-blue-600 hover:bg-blue-50')
            }`}
        >
          Français
        </a>
      </div>
    )}

    {course === 'math9' && (
      <div class="flex gap-1 pb-2 overflow-x-auto">
        {math9Strands.map(s => (
          <a
            href={`${base}math9/materials/${s.slug}`}
            class={`text-xs px-2.5 py-1 rounded-md font-medium whitespace-nowrap transition-colors
              ${currentPath.includes(s.slug)
                ? 'bg-math9-600 text-white'
                : 'text-slate-600 hover:bg-slate-100'
              }`}
          >
            {s.label}
          </a>
        ))}
        <a
          href={`${base}math9/materials`}
          class={`text-xs px-2.5 py-1 rounded-md font-medium whitespace-nowrap transition-colors
            ${currentPath.endsWith('/math9/materials') || currentPath.endsWith('/math9/materials/')
              ? 'bg-math9-600 text-white'
              : 'text-slate-600 hover:bg-slate-100'
            }`}
        >
          All Materials
        </a>
      </div>
    )}

  </div>
</nav>
